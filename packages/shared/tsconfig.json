{
  "extends": "../../configs/typescript/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "noEmit": false,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./.generated/tsconfig.tsbuildinfo",
    
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    
    "types": [
      "node",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json"
  ],
  "exclude": [
    "dist",
    "dist/**",
    "./dist",
    "./dist/**",
    "**/dist",
    "**/dist/**",
    "./.generated",
    "./.generated/**",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ]
}