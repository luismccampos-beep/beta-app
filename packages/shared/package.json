{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@akmleva/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./types/ai-preferences": {
      "types": "./dist/types/ai-preferences/index.d.ts",
      "import": "./dist/types/ai-preferences/index.js",
      "default": "./dist/types/ai-preferences/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "default": "./dist/validation/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js",
      "default": "./dist/helpers/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "default": "./dist/logger/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js",
      "default": "./dist/themes/index.js"
    },
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js",
      "default": "./dist/locales/index.js"
    },
    "./locales/en": {
      "types": "./dist/locales/en/index.d.ts",
      "import": "./dist/locales/en/index.js",
      "default": "./dist/locales/en/index.js"
    },
    "./locales/pt": {
      "types": "./dist/locales/pt/index.d.ts",
      "import": "./dist/locales/pt/index.js",
      "default": "./dist/locales/pt/index.js"
    },
    "./locales/es": {
      "types": "./dist/locales/es/index.d.ts",
      "import": "./dist/locales/es/index.js",
      "default": "./dist/locales/es/index.js"
    },
    "./locales/fr": {
      "types": "./dist/locales/fr/index.d.ts",
      "import": "./dist/locales/fr/index.js",
      "default": "./dist/locales/fr/index.js"
    },
    "./locales/types": {
      "types": "./dist/locales/types.d.ts",
      "import": "./dist/locales/types.js",
      "default": "./dist/locales/types.js"
    },
    "./lib/i18n": {
      "types": "./dist/lib/i18n/index.d.ts",
      "import": "./dist/lib/i18n/index.js",
      "default": "./dist/lib/i18n/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./components/layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.js",
      "default": "./dist/components/layout/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "npm run clean && tsup --config tsup.config.ts && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "build:dev": "npm run clean && tsc -b tsconfig.json && tsup --config tsup.config.ts --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo .generated",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "npm run clean && tsc --watch"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/react": "^10.36.0",
    "class-variance-authority": "^0.7.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "next": "^15.5.2",
    "react-day-picker": "^9.13.0",
    "react-markdown": "^9.1.0",
    "react-window": "^2.2.6",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "clsx": "^2.1.1",
    "eslint": "^9.9.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.1.3",
    "framer-motion": "^11.18.2",
    "i18next": "^23.16.8",
    "idb": "^8.0.3",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.454.0",
    "msw": "^2.12.10",
    "prettier": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^13.5.0",
    "rimraf": "^5.0.5",
    "tailwind-merge": "^3.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "i18next": "^23.16.8",
    "lucide-react": "^0.454.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^13.5.0",
    "tailwind-merge": "^3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "volta": {
    "node": "20.10.0"
  }
}
