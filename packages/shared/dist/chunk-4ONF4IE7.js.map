    "faqs": {
      "faq-001": {
        "question": "Comment puis-je annuler ma réservation ?",
        "answer": "Vous pouvez annuler votre réservation via l'espace \"Mes Voyages\" ou en contactant notre support."
      },
      "faq-002": {
        "question": "Quels sont les modes de paiement acceptés ?",
        "answer": "Nous acceptons les cartes de crédit/débit (Visa, Mastercard, American Express), PayPal et les virements."
      },
      "faq-003": {
        "question": "Comment modifier les détails de ma réservation ?",
        "answer": "Les modifications peuvent être effectuées via l'espace \"Mes Voyages\" jusqu'à 24 heures avant le départ."
      },
      "faq-004": {
        "question": "Que faire se je perds mon voucher ?",
        "answer": "Vous pouvez re-télécharger votre voucher via l'espace \"Mes Voyages\" ou contacter le support."
      },
      "faq-005": {
        "question": "Comment fonctionne le programme de fidélité ?",
        "answer": "Notre programme de fidélité offre des points pour chaque réservation. Ceux-ci peuvent être échangés contre des réductions."
      },
