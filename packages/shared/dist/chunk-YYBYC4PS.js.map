    "faqs": {
      "faq-001": {
        "question": "¿Cómo puedo cancelar mi reserva?",
        "answer": "Puede cancelar su reserva a través del área \"Mis Viajes\" en su perfil o contactando a nuestro soporte."
      },
      "faq-002": {
        "question": "¿Qué métodos de pago se aceptan?",
        "answer": "Aceptamos tarjetas de crédito/débito (Visa, Mastercard, American Express), PayPal y transferencias bancarias."
      },
      "faq-003": {
        "question": "¿Cómo puedo cambiar los detalles de mi reserva?",
        "answer": "Los cambios pueden realizarse a través del área \"Mis Viajes\" hasta 24 horas antes de la fecha de salida."
      },
      "faq-004": {
        "question": "¿Qué hacer si pierdo mi voucher?",
        "answer": "Puede volver a descargar su voucher a través del área \"Mis Viajes\" o contactar con soporte."
      },
      "faq-005": {
        "question": "¿Cómo funciona el programa de fidelización?",
        "answer": "Nuestro programa de fidelización ofrece puntos por cada reserva. Estos se podem canjear por descuentos en futuros viajes."
      },
      "faq-006": {
        "question": "¿Puedo hacer reservas para grupos?",
        "answer": "¡Sí! Para reservas de grupos (10 o más personas), ofrecemos condiciones especiales."
      }
