        { "category": "Datos de Contacto", "examples": ["Email", "Teléfono", "Dirección postal"], "retention": "3 años tras la última interacción", "retentionColor": "green" }
      ],
      "note": "Los plazos de conservación pueden ser mayores cuando lo exija la ley o menores en caso de ejercicio de derechos.",
      "mobileHint": "Deslice a la derecha para ver los ejemplos completos"
    },
    "dataCategories": {
