    "introduction": {
      "title": "Nuestra política de privacidad",
      "intro": "AKMLEVA está plenamente comprometida con la protección de su privacidad y sus datos personales, en estricta conformidad con el Reglamento General de Protección de Datos (RGPD/UE 2016/679) y la legislación aplicable.",
      "trust": {
        "transparency": "Transparencia total",
        "compliance": "Conformidad RGPD"
      }
    },
    "footer": {
      "effectiveSinceLabel": "En vigor desde:",
      "defaultEffectiveDate": "25 de Mayo de 2018",
      "statementPrefix": "Este documento está plenamente en conformidad con el",
      "regulationName": "Reglamento (UE) 2016/679",
      "statementSuffix": "(RGPD/GDPR) y la legislación nacional aplicable.",
      "lastUpdatedLabel": "Última actualización: {date}",
      "trustLine": "Compromiso con la transparencia y la protección de sus derechos",
      "branding": "Política de Privacidad y Protección de Datos • AKMLEVA"
    },
    "dataProcessing": {
      "title": "Finalidades del Tratamiento de Datos Personales",
      "intro": "Tratamos sus datos personales solo para finalidades específicas, explícitas y legítimas, en conformidad con el RGPD.",
      "legalBasisLabel": "Base legal",
      "purposes": [
        {
          "title": "Prestación de Servicios y Gestión de Reservas",
          "description": "Procesar reservas de viajes, alojamiento, transportes y actividades turísticas, gestionar pagos, emitir documentos de viaje y prestar soporte al cliente durante y después del viaje.",
          "legalBasis": "Ejecución de contrato (Art. 6(1)(b) RGPD)",
          "basisColor": "blue"
        },
        {
          "title": "Cumplimiento de Obligaciones Legales",
          "description": "Cumplir obligaciones fiscales, contables y regulatorias, conservar facturas y registros de viaje por motivos legales.",
          "legalBasis": "Obligación legal (Art. 6(1)(c) RGPD)",
          "basisColor": "purple"
        },
        {
          "title": "Marketing y Comunicación Personalizada",
          "description": "Enviar newsletters, promociones, ofertas personalizadas, encuestas de satisfacción e información sobre destinos similares a los reservados previamente.",
          "legalBasis": "Consentimiento (Art. 6(1)(a) RGPD)",
          "basisColor": "green"
        },
        {
          "title": "Prevención de Fraude y Seguridad",
          "description": "Verificar identidad en reservas, prevenir fraudes de pago, detectar actividades sospechosas y proteger sistemas y datos de clientes.",
          "legalBasis": "Interés legítimo (Art. 6(1)(f) RGPD)",
          "basisColor": "amber"
        },
        {
          "title": "Mejora del Servicio y Análisis Estadístico",
          "description": "Analizar patrones de uso, preferencias y feedback para mejorar los servicios y personalizar ofertas.",
          "legalBasis": "Interés legítimo (Art. 6(1)(f) RGPD)",
          "basisColor": "amber"
        }
      ],
      "note": "No tratamos sus datos para finalidades incompatibles con las aquí descritas sin una nueva base legal o su consentimiento explícito."
    },
    "dataSecurity": {
      "title": "Medidas de Seguridad de los Datos",
      "intro": "Adoptamos medidas técnicas y organizativas adecuadas y actualizadas para garantizar un nivel de seguridad proporcional al riesgo, en conformidad con el artículo 32 del RGPD.",
      "measures": [
        { "text": "Cifrado TLS 1.3 en tránsito y AES-256 en reposo (bases de datos y backups)", "important": true },
        { "text": "Autenticación multifactor (MFA) para todos los accesos administrativos y sistemas críticos", "important": true },
        { "text": "Control de acceso basado en roles (RBAC) y principio de mínimo privilegio" },
        { "text": "Monitorización, detección de intrusiones y registros de auditoría" },
        { "text": "Auditorías de seguridad y pruebas de penetración periódicas" }
      ],
      "note": "A pesar de las medidas implementadas, ningún sistema es 100% inmune a riesgos. En caso de violación de datos, notificaremos a la autoridad de control y a los titulares afectados dentro de los plazos legales."
    },
    "dataTypes": {
