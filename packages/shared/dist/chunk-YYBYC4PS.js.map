            "legalBasis": "Interés legítimo"
          }
        ]
      },
      "rights": {
        "title": "Sus Derechos",
        "description": "Bajo el RGPD, usted tiene varios derechos en relación con sus datos personales:",
        "list": [
          {
            "title": "Derecho de Acceso",
            "description": "Derecho a obtener confirmación sobre si sus datos están siendo tratados y a acceder a ellos."
          },
          {
            "title": "Derecho de Rectificación",
            "description": "Derecho a solicitar la corrección de datos inexactos o incompletos."
          },
          {
            "title": "Derecho al Olvido",
            "description": "Derecho a solicitar la eliminación de sus datos en determinadas circunstancias."
          },
          {
            "title": "Derecho a la Portabilidad",
            "description": "Derecho a recibir sus datos en un formato estructurado y de uso común."
          },
          {
            "title": "Derecho de Oposición",
            "description": "Derecho a oponerse al tratamiento de sus datos para fines específicos, como marketing directo."
          }
        ]
      },
      "dataSecurity": {
        "title": "Seguridad de los Datos",
        "content": "Implementamos medidas técnicas y organizativas adecuadas para proteger sus datos personales contra destrucción, pérdida, alteración, divulgación o acceso no autorizado."
      },
      "dataTransfer": {
        "title": "Transferencias Internacionales",
        "content": "Para la prestación de servicios de viaje internacionales, puede ser necesario transferir sus datos a proveedores fuera del Espacio Económico Europeo. En estos casos, garantizamos que se aplican las salvaguardias adecuadas de acuerdo con el RGPD."
      },
      "retention": {
        "title": "Conservación de Datos",
        "content": "Conservamos sus datos personales solo durante el tiempo necesario para las finalidades para las que fueron recopilados, o para cumplir con obligaciones legales."
      },
      "complaints": {
        "title": "Reclamaciones",
        "content": "Si considera que el tratamiento de sus datos personales infringe el RGPD, tiene derecho a presentar una reclamación ante la autoridad de control (en Portugal, la CNPD - Comissão Nacional de Proteção de Dados)."
      }
    }
  },
