  "cancellationPage": {
    "hero": {
      "title": "Política de Cancelación",
      "subtitle": "Información clara para su seguridad y planificación."
    },
    "sectionPolicy": {
      "title": "Nuestra Política en Detalle",
      "intro": "Para garantizar transparencia, detallamos las condiciones aplicables. Recomendamos una lectura atenta.",
      "sections": [
        {
          "title": "Condiciones Generales",
          "points": [
            "Todas las solicitudes deben hacerse por escrito vía email.",
            "El cálculo se basa en la fecha de recepción de la solicitud.",
            "Las tasas de servicio y administrativas no son reembolsables."
          ]
        },
        {
          "title": "Plazos y Tasas (Paquetes Terrestres)",
          "points": [
            "Cancelación con más de 30 días de antelación: Tasa de retención del 20%.",
            "Cancelación entre 29 y 15 días: Tasa de retención del 50%.",
            "Cancelación con menos de 14 días: Sin reembolso."
          ],
          "periods": [
            {
              "period": "Más de 30 días antes",
              "fee": "Tasa de retención del 20%"
            },
            {
              "period": "Entre 29 y 15 días antes",
              "fee": "Tasa de retención del 50%"
            },
            {
              "period": "Menos de 14 días antes",
              "fee": "Sin reembolso"
            }
          ]
        },
        {
          "title": "Vuelos",
          "points": [
            "Las políticas de cancelación de vuelos son dictadas por las aerolíneas y pueden ser 100% no reembolsables."
          ]
        }
      ],
      "important": {
        "title": "Importante",
        "description": "En caso de cancelación por motivos de fuerza mayor (pandemia, catástrofes naturales, etc.), se aplican condiciones especiales. Contáctenos para más información."
      }
    },
    "sectionHowTo": {
      "title": "Cómo Solicitar una Cancelación",
      "steps": [
        {
          "title": "1. Contactar Soporte",
          "description": "La forma más rápida y segura es a través del email oficial de soporte.",
          "icon": "mail"
        },
        {
          "title": "2. Proporcionar Detalles",
          "description": "Por favor, indique su número de reserva, nombre completo y motivo de la cancelación.",
          "icon": "info"
        },
        {
          "title": "3. Esperar Confirmación",
          "description": "Recibirá una confirmación por email con los detalles del procesamiento.",
          "icon": "check"
        }
      ]
    },
    "sectionFaq": {
      "title": "Preguntas Frecuentes",
      "questions": [
        {
          "q": "¿Puedo cancelar mi reserva online?",
          "a": "Actualmente, todas las cancelaciones deben procesarse a través de nuestro soporte por email para garantizar seguridad y precisión."
        },
        {
          "q": "¿Cuánto tiempo tarda el reembolso?",
          "a": "Los reembolsos se procesan entre 5 a 10 días hábiles después de la confirmación de cancelación, dependiendo del método de pago original."
        },
        {
          "q": "¿Puedo cambiar en lugar de cancelar?",
          "a": "¡Sí! A menudo es posible cambiar fechas o destinos. Contáctenos para verificar las opciones disponibles para su reserva."
        }
      ]
    },
    "needHelp": {
      "title": "¿Necesita Ayuda?",
      "description": "Nuestro equipo está aquí para ayudarle con cualquier pregunta sobre cancelaciones."
    },
    "contactSupport": {
      "title": "Contactar Soporte",
      "description": "Para cancelaciones o preguntas, contáctenos directamente.",
      "button": "Enviar Email"
    },
    "myBookings": {
      "title": "Mis Reservas",
      "description": "Acceda a su área personal para ver todas sus reservas.",
      "button": "Ver Reservas"
    },
    "ui": {
      "loading": "Cargando política de cancelación...",
      "refundTimeline": {
        "title": "Cronología de Reembolso",
        "description": "Consulte la tabla anterior para entender las tarifas aplicables según el período de cancelación."
      },
      "howToHint": "El proceso es simple y automático a través de su área de cliente."
    }
  },
  "cookiesPage": {
    "title": "Política de Cookies",
    "lastUpdated": "Última actualización: {{date}}",
    "introduction": "Esta Política de Cookies explica cómo AKMLEVA utiliza cookies y tecnologías similares en nuestro sitio web para mejorar su experiencia de navegación.",
    "ui": {
      "readingProgressAria": "Progreso de lectura",
      "privacyCenterBadge": "Centro de Privacidad",
      "aboutThisPolicy": "Sobre esta política",
      "preferences": {
        "title": "Preferencias de Cookies",
        "description": "Respetamos su privacidad. Puede ajustar su configuración en cualquier momento para controlar lo que comparte con nosotros.",
        "ariaManageSettings": "Gestionar la configuración de cookies",
        "manageSettings": "Gestionar configuración",
        "cardTitle": "Preferencias",
        "cardDescription": "Controle cómo se usan sus datos.",
        "ariaManageCookies": "Gestionar cookies",
        "manageCookies": "Gestionar Cookies",
        "necessary": "Necesarias",
        "necessaryDesc": "Estas cookies son esenciales para el funcionamiento del sitio web y no se pueden desactivar.",
        "functional": "Funcionales",
        "functionalDesc": "Permiten funciones mejoradas y personalización (por ejemplo, recordar preferencias).",
        "analytics": "Analíticas",
        "analyticsDesc": "Nos ayudan a medir y mejorar el rendimiento del sitio mediante estadísticas agregadas.",
        "marketing": "Marketing",
        "marketingDesc": "Se utilizan para mostrar contenido y anuncios más relevantes para usted.",
        "reset": "Restablecer",
        "save": "Guardar"
      }
    },
    "sections": {
      "whatAreCookies": {
        "title": "¿Qué son las cookies?",
        "content": [
          {
            "type": "paragraph",
            "text": "Las cookies son pequeños archivos de texto que un sitio web coloca en su ordenador o dispositivo móvil cuando lo visita a través de su navegador de internet. Las cookies ayudan al sitio a reconocer su dispositivo la próxima vez que lo visite, reteniendo solo información relacionada con sus preferencias, y no incluyen sus datos personales."
          },
          {
            "type": "paragraph",
            "text": "En esta política, usamos el término 'cookies' para referirnos a todos los archivos que recopilan información de esta manera."
          }
        ]
      },
      "whyWeUseCookies": {
        "title": "2. ¿Para qué sirven las Cookies?",
        "content": [
          {
            "type": "paragraph",
            "text": "Utilizamos cookies para mejorar su experiencia de navegación, haciéndola más rápida y eficiente, y para personalizar nuestros servicios. Nos permiten:"
          },
          {
            "type": "list",
            "items": [
              "Garantizar que el sitio web funcione correctamente.",
              "Recordar sus preferencias, como el idioma o el destino de su última búsqueda.",
              "Recopilar estadísticas anónimas sobre el uso del sitio, para que podamos identificar áreas de mejora.",
              "Presentar publicidad y recomendaciones de viaje relevantes para sus intereses."
            ]
          }
        ]
      },
      "typesOfCookies": {
        "title": "3. Tipos de Cookies que Utilizamos",
        "content": [
          {
            "type": "paragraph",
            "text": "En cumplimiento con la legislación, solicitamos su consentimiento para usar cookies, excepto aquellas que son estrictamente necesarias para el funcionamiento del sitio. Puede gestionar su consentimiento en cualquier momento. Las cookies que usamos se categorizan de la siguiente manera:"
          },
          {
            "type": "cookie_type",
            "text": "Cookies Estrictamente Necesarias",
            "description": "Estas cookies son esenciales para que pueda navegar por el sitio web y usar sus funcionalidades, como acceder a áreas seguras (inicio de sesión). Sin estas cookies, los servicios que solicitó, como completar una reserva, no pueden proporcionarse. <strong>Estas cookies no pueden desactivarse.</strong>",
            "items": [
              "Gestión de su sesión de usuario.",
              "Procesamiento de su carrito de compras y proceso de pago.",
              "Garantizar la seguridad del sitio web."
            ]
          },
          {
            "type": "cookie_type",
            "text": "Cookies de Rendimiento y Análisis",
            "description": "Estas cookies recopilan información sobre cómo los usuarios utilizan el sitio web, por ejemplo, qué páginas son más visitadas o si reciben mensajes de error. La información es agregada y anónima, y sirve solo para mejorar el funcionamiento de nuestro sitio.",
            "items": [
              "<strong>Google Analytics:</strong> Nos ayuda a entender cómo los visitantes interactúan con el sitio, permitiéndonos optimizar nuestra oferta.",
              "Medición de la efectividad de nuestras campañas."
            ]
          },
          {
            "type": "cookie_type",
            "text": "Cookies de Funcionalidad",
            "description": "Estas cookies permiten que el sitio web recuerde las elecciones que hace (como su nombre de usuario, idioma o región) y proporcionan funcionalidades mejoradas y más personales. Por ejemplo, pueden usarse para recordar los detalles de su última búsqueda de viaje.",
            "items": [
              "Recordar sus preferencias de idioma y moneda.",
              "Guardar su historial de búsquedas recientes para facilitar futuras consultas."
            ]
          },
          {
            "type": "cookie_type",
            "text": "Cookies de Publicidad y Marketing",
            "description": "Estas cookies se utilizan para dirigir la publicidad en función de los intereses de cada usuario, limitando el número de veces que ve un anuncio y ayudando a medir la efectividad de la publicidad. Pueden compartirse con terceros, como Google o Facebook, para crear perfiles de interés y presentarle anuncios relevantes en otros sitios web.",
            "items": [
              "<strong>Google Ads:</strong> Para presentar anuncios personalizados basados en sus búsquedas.",
              "<strong>Meta (Facebook/Instagram) Pixel:</strong> Para crear audiencias personalizadas y medir el éxito de campañas en redes sociales."
            ]
          }
        ]
      },
      "manageCookies": {
        "title": "4. Cómo Gestionar sus Cookies",
        "content": [
          {
            "type": "paragraph",
            "text": "Su consentimiento es fundamental. Al visitar nuestro sitio por primera vez, se le presentará un banner de cookies donde puede aceptar, rechazar o personalizar sus preferencias. Puede cambiar sus elecciones en cualquier momento haciendo clic en el botón de abajo:"
          },
          {
            "type": "subheading",
            "text": "Gestión a través del Navegador"
          },
          {
            "type": "paragraph",
            "text": "Adicionalmente, todos los navegadores permiten a los usuarios aceptar, rechazar o eliminar cookies, especialmente a través de la selección de configuraciones apropiadas en el navegador respectivo. Tenga en cuenta que al desactivar cookies, puede impedir que algunos servicios web funcionen correctamente, afectando parcial o totalmente la navegación en el sitio web."
          }
        ]
      }
    }
  },
  "gdprComponents": {
