    "introduction": {
      "title": "A nossa política de privacidade",
      "intro": "A AKMLEVA está plenamente comprometida com a proteção da sua privacidade e dos seus dados pessoais, em estrita conformidade com o Regulamento Geral sobre a Proteção de Dados (RGPD/UE 2016/679) e demais legislação aplicável.",
      "trust": {
        "transparency": "Transparência total",
        "compliance": "Conformidade RGPD"
      }
    },
    "footer": {
      "effectiveSinceLabel": "Em vigor desde:",
      "defaultEffectiveDate": "25 de Maio de 2018",
      "statementPrefix": "Este documento está plenamente em conformidade com o",
      "regulationName": "Regulamento (UE) 2016/679",
      "statementSuffix": "(RGPD/GDPR) e legislação nacional aplicável.",
      "lastUpdatedLabel": "Última atualização: {date}",
      "trustLine": "Compromisso com transparência e proteção dos seus direitos",
      "branding": "Política de Privacidade & Proteção de Dados • AKMLEVA"
    },
    "dataProcessing": {
      "title": "Finalidades do Tratamento de Dados Pessoais",
      "intro": "Tratamos os seus dados pessoais apenas para finalidades específicas, explícitas e legítimas, em conformidade com o Regulamento Geral de Proteção de Dados (RGPD).",
      "legalBasisLabel": "Base Legal",
      "purposes": [
        {
          "title": "Prestação de Serviços e Gestão de Reservas",
          "description": "Processar reservas de viagens, alojamento, transportes e atividades turísticas, gerir pagamentos, emitir documentos de viagem e prestar suporte ao cliente durante e após a viagem.",
          "legalBasis": "Execução de contrato (Art. 6(1)(b) RGPD)",
          "basisColor": "blue"
        },
        {
          "title": "Cumprimento de Obrigações Legais",
          "description": "Cumprir obrigações fiscais, contabilísticas, de reporte às autoridades (ex: SEF/IEF para alojamento local), conservação de faturas e registos de viagem por motivos legais.",
          "legalBasis": "Obrigação legal (Art. 6(1)(c) RGPD)",
          "basisColor": "purple"
        },
        {
          "title": "Marketing e Comunicação Personalizada",
          "description": "Enviar newsletters, promoções, ofertas personalizadas, inquéritos de satisfação e informações sobre destinos semelhantes aos previamente reservados.",
          "legalBasis": "Consentimento do titular (Art. 6(1)(a) RGPD)",
          "basisColor": "green"
        },
        {
          "title": "Prevenção de Fraude e Segurança",
          "description": "Verificar identidade em reservas, prevenir fraudes em pagamentos, detetar atividades suspeitas e proteger os sistemas e os dados dos clientes.",
          "legalBasis": "Interesses legítimos (Art. 6(1)(f) RGPD)",
          "basisColor": "amber"
        },
        {
          "title": "Melhoria de Serviços e Análise Estatística",
          "description": "Analisar padrões de utilização, preferências de viagem e feedback para melhorar os serviços, personalizar ofertas e realizar estudos de mercado agregados.",
          "legalBasis": "Interesses legítimos (Art. 6(1)(f) RGPD)",
          "basisColor": "amber"
        }
      ],
      "note": "Não tratamos os seus dados para finalidades incompatíveis com as aqui descritas sem uma nova base legal ou o seu consentimento explícito."
    },
    "dataSecurity": {
      "title": "Medidas de Segurança dos Dados",
      "intro": "Adotamos medidas técnicas e organizacionais adequadas e atualizadas para garantir um nível de segurança proporcional ao risco, em conformidade com o artigo 32.º do RGPD.",
      "measures": [
        { "text": "Encriptação TLS 1.3 em trânsito e AES-256 em repouso (dados em bases de dados e backups)", "important": true },
        { "text": "Autenticação multifator (MFA) para todos os acessos administrativos e sistemas críticos", "important": true },
        { "text": "Controlo de acesso baseado em papéis (RBAC) e princípio do mínimo privilégio" },
        { "text": "Monitorização em tempo real, deteção de intrusões (IDS/IPS) e registos de auditoria" },
        { "text": "Formação anual obrigatória em proteção de dados e cibersegurança para todos os colaboradores" },
        { "text": "Auditorias de segurança independentes e testes de penetração periódicos" },
        { "text": "Planos de resposta a incidentes e recuperação de desastres testados regularmente" }
      ],
      "note": "Apesar das medidas implementadas, nenhum sistema é 100% imune a riscos. Em caso de violação de dados, notificaremos a autoridade de controlo e os titulares afetados dentro dos prazos legais."
    },
