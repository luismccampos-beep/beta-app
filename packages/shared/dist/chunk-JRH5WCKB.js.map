    "faqs": {
      "faq-001": {
        "question": "Como posso cancelar a minha reserva?",
        "answer": "Pode cancelar a sua reserva através da área \"Minhas Viagens\" no seu perfil ou contactando o nosso suporte. As condições de cancelamento variam conforme o tipo de serviço reservado."
      },
      "faq-002": {
        "question": "Quais são os métodos de pagamento aceites?",
        "answer": "Aceitamos cartões de crédito/débito (Visa, Mastercard, American Express), PayPal, transferência bancária e MB Way. Todos os pagamentos são processados de forma segura."
      },
      "faq-003": {
        "question": "Como posso alterar os dados da minha reserva?",
        "answer": "Alterações podem ser feitas através da área \"Minhas Viagens\" até 24 horas antes da data de partida. Algumas alterações podem estar sujeitas a taxas adicionais."
      },
      "faq-004": {
        "question": "O que fazer se perder o meu voucher?",
        "answer": "Pode descarregar novamente o seu voucher através da área \"Minhas Viagens\" ou contactar o nosso suporte para reenvio por email."
      },
      "faq-005": {
        "question": "Como funciona o programa de fidelidade?",
        "answer": "O nosso programa de fidelidade oferece pontos por cada reserva. Estes pontos podem ser trocados por descontos em futuras viagens."
      },
      "faq-006": {
        "question": "Posso fazer reservas para grupos?",
        "answer": "Sim! Para reservas de grupos (10 ou mais pessoas), oferecemos condições especiais e um gestor de conta dedicado."
      }
    },
