    "sections": {
      "whatAreCookies": {
        "title": "O que são Cookies?",
        "content": [
          {
            "type": "paragraph",
            "text": "Cookies são pequenos ficheiros de texto que são armazenados no seu dispositivo quando visita um website. Estes ficheiros permitem que o website reconheça o seu dispositivo e armazene algumas informações sobre as suas preferências ou ações passadas."
          }
        ]
      },
      "typesOfCookies": {
        "title": "Tipos de Cookies que Utilizamos",
        "content": [
          {
            "type": "list",
            "items": [
              "<strong>Cookies Essenciais:</strong> Necessários para o funcionamento básico do website.",
              "<strong>Cookies de Performance:</strong> Ajudam-nos a entender como os visitantes interagem com o nosso website.",
              "<strong>Cookies de Funcionalidade:</strong> Permitem que o website se lembre das suas escolhas e forneça funcionalidades melhoradas.",
              "<strong>Cookies de Marketing:</strong> Utilizados para fornecer anúncios mais relevantes para si e para os seus interesses."
            ]
          }
        ]
      },
      "manageCookies": {
        "title": "Como Gerir os Cookies",
        "content": [
          {
            "type": "paragraph",
            "text": "Pode controlar e/ou eliminar cookies conforme desejar. Pode eliminar todos os cookies que já estão no seu computador e pode configurar a maioria dos navegadores para impedir que sejam colocados."
          }
        ]
      }
    }
  },
