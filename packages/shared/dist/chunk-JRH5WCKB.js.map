        { "category": "Dados de Reserva e Pagamento", "examples": ["Detalhes da reserva (datas, destinos, serviços contratados)", "Informações de pagamento (últimos 4 dígitos do cartão, IBAN em caso de transferência)", "Histórico de viagens"], "retention": "7 anos (obrigação legal fiscal)", "retentionColor": "red" },
