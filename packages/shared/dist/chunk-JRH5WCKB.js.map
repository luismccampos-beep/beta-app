  "cancellationPage": {
    "hero": {
      "title": "Política de Cancelamento",
      "subtitle": "Informações claras para a sua segurança e planeamento."
    },
    "sectionPolicy": {
      "title": "A Nossa Política em Detalhe",
      "intro": "Para garantir transparência, detalhamos as condições aplicáveis. Recomendamos uma leitura atenta.",
      "sections": [
        {
          "title": "Condições Gerais",
          "points": [
            "Todos os pedidos devem ser feitos por escrito via email.",
            "O cálculo é baseado na data de receção do pedido.",
            "Taxas de serviço e administrativas são não reembolsáveis."
          ]
        },
        {
          "title": "Prazos e Taxas (Pacotes Terrestres)",
          "points": [
            "Cancelamento com mais de 30 dias de antecedência: Taxa de retenção de 20%.",
            "Cancelamento entre 29 e 15 dias: Taxa de retenção de 50%.",
            "Cancelamento com menos de 14 dias: Sem reembolso."
          ],
          "periods": [
            {
              "period": "Mais de 30 dias antes",
              "fee": "Taxa de retenção de 20%"
            },
            {
              "period": "Entre 29 e 15 dias antes",
              "fee": "Taxa de retenção de 50%"
            },
            {
              "period": "Menos de 14 dias antes",
              "fee": "Sem reembolso"
            }
          ]
        },
        {
          "title": "Voos",
          "points": [
            "As políticas de cancelamento de voos são ditadas pelas companhias aéreas e podem ser 100% não reembolsáveis."
          ]
        }
      ],
      "important": {
        "title": "Importante",
        "description": "Em caso de cancelamento por motivos de força maior (pandemia, catástrofes naturais, etc.), aplicam-se condições especiais. Contacte-nos para mais informações."
      }
    },
    "sectionHowTo": {
      "title": "Como Solicitar um Cancelamento",
      "steps": [
        {
          "title": "1. Contacte o Suporte",
          "description": "A forma mais rápida e segura é através do email oficial de suporte.",
          "icon": "mail"
        },
        {
          "title": "2. Forneça os Detalhes",
          "description": "Por favor, indique o seu número de reserva, nome completo e o motivo do cancelamento.",
          "icon": "info"
        },
        {
          "title": "3. Aguarde Confirmação",
          "description": "Receberá uma confirmação por email com os detalhes do processamento.",
          "icon": "check"
        }
      ]
    },
    "sectionFaq": {
      "title": "Perguntas Frequentes",
      "questions": [
        {
          "q": "Posso cancelar a minha reserva online?",
          "a": "Atualmente, todos os cancelamentos devem ser processados através do nosso suporte por email para garantir a segurança e precisão."
        },
        {
          "q": "Quanto tempo demora o reembolso?",
          "a": "Os reembolsos são processados entre 5 a 10 dias úteis após a confirmação do cancelamento, dependendo do método de pagamento original."
        },
        {
          "q": "Posso alterar em vez de cancelar?",
          "a": "Sim! Muitas vezes é possível alterar datas ou destinos. Contacte-nos para verificar as opções disponíveis para a sua reserva."
        }
      ]
    },
    "needHelp": {
      "title": "Precisa de Ajuda?",
      "description": "A nossa equipa está aqui para o ajudar com qualquer questão sobre cancelamentos."
    },
    "contactSupport": {
      "title": "Contactar Suporte",
      "description": "Para cancelamentos ou dúvidas, contacte-nos diretamente.",
      "button": "Enviar Email"
    },
    "myBookings": {
      "title": "As Minhas Reservas",
