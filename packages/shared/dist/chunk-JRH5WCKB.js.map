    "userRights": {
      "title": "Os Seus Direitos enquanto Titular de Dados",
      "intro": "O RGPD garante-lhe vários direitos poderosos sobre os seus dados pessoais. Pode exercê-los a qualquer momento contactando-nos através dos contactos indicados na secção “Responsável pelo Tratamento”.",
      "items": [
        { "right": "Direito de Acesso", "description": "Pode solicitar confirmação de que tratamos os seus dados pessoais e obter uma cópia dos mesmos, incluindo as finalidades, categorias, destinatários e prazos de conservação.", "important": true },
        { "right": "Direito de Retificação", "description": "Pode solicitar a correção imediata de dados pessoais inexatos ou incompletos que tenhamos sobre si." },
        { "right": "Direito ao Apagamento (“Direito ao Esquecimento”)", "description": "Pode pedir a eliminação dos seus dados pessoais quando já não sejam necessários para a finalidade original, quando retire o consentimento, ou em outras situações previstas no RGPD.", "important": true },
        { "right": "Direito à Limitação do Tratamento", "description": "Pode solicitar a suspensão temporária do tratamento em certas circunstâncias (ex.: enquanto verifica a exatidão dos dados ou quando se opõe ao tratamento)." },
        { "right": "Direito à Portabilidade dos Dados", "description": "Pode receber os seus dados pessoais num formato estruturado, de uso corrente e leitura automática, e transmiti-los a outro responsável, quando o tratamento se baseie no consentimento ou em contrato." },
        { "right": "Direito de Oposição", "description": "Pode opor-se ao tratamento dos seus dados para marketing direto (a qualquer momento) ou por motivos relacionados com a sua situação particular em casos de interesse legítimo.", "important": true },
        { "right": "Direito de Não Ser Sujeito a Decisões Automatizadas", "description": "Tem o direito de não ser sujeito a decisões baseadas exclusivamente em tratamento automatizado, incluindo definição de perfis, que produzam efeitos jurídicos ou o afetem significativamente." }
      ],
      "footer": {
        "prefix": "Para exercer qualquer um destes direitos, basta contactar-nos através do email",
        "email": "privacy@akmleva.pt",
        "suffix": ". Responderemos no prazo máximo de um mês (prorrogável em casos complexos)."
      }
    },
    "contact": {
      "title": "Contacto e Exercício de Direitos GDPR",
      "intro": "Para exercer os seus direitos (acesso, retificação, apagamento, oposição, portabilidade, limitação) ou esclarecer qualquer dúvida sobre o tratamento dos seus dados pessoais, contacte-nos através dos meios abaixo:",
