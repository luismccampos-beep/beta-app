  "story": {
    "title1": "Our",
    "title2": "Story",
    "subtitle": "Since our founding, we have been dedicated to turning dreams into reality.",
    "visionTitle": "Vision and Mission",
    "paragraph1": "AKMLEVA was born from a passion for exploring the world and the belief that every journey should be a transformative experience. Founded with the aim of going beyond conventional tourism, we seek to create itineraries that not only showcase destinations but also connect travelers with local culture and the essence of each place.",
    "paragraph2": "We believe that the true richness of a trip lies in the memories created, the people met, and the broadened perspectives. Therefore, every detail is carefully planned to exceed expectations, from the choice of accommodation to the most authentic activities.",
    "ourMission": "Our Mission",
    "missionStatement": "To inspire and facilitate life-enriching travel, promoting discovery and respect for the diverse cultures of the world.",
