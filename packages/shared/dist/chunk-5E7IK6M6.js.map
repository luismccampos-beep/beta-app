  "privacyPage": {
    "title": "Privacy Policy",
    "ui": {
      "badge": "Transparency & Trust",
      "tocTitle": "Table of Contents",
      "updatedLabel": "Updated:",
      "applicableLabel": "Applicable: Portugal / EU",
      "share": {
        "title": "Share",
        "description": "Share this policy so others can review this information.",
        "button": "Share"
      },
      "printVersion": {
        "title": "Printable version",
        "description": "Download the full policy in PDF format for your records.",
        "download": "Download PDF"
      },
      "intro": "This Privacy Policy describes how we collect, use and protect your personal information when you use our website and services. By using AKMLEVA, you agree to the collection and use of information in accordance with this policy.",
      "contactDpo": "Contact our DPO",
      "backToTopAria": "Back to top"
    },
    "introduction": {
      "title": "Introduction",
      "content": [
        "At AKMLEVA, we value your privacy and are committed to protecting your personal data. This privacy policy explains how we collect, use, and protect your information when you use our travel services.",
        "This policy complies with the General Data Protection Regulation (GDPR) and Portuguese data protection legislation."
      ]
    },
    "sections": [
      {
        "title": "1. Data Collection",
        "content": [
          "We collect the following types of personal data:",
          "<ul><li><strong>Identification Data:</strong> Name, email, phone, address, date of birth</li><li><strong>Travel Data:</strong> Destination preferences, travel dates, special requirements</li><li><strong>Payment Data:</strong> Credit card information, billing address (processed securely)</li><li><strong>Behavioral Data:</strong> Website interactions, search preferences, service usage</li></ul>"
        ]
      },
      {
        "title": "2. AI Usage and Data Processing",
        "content": [
          "We use artificial intelligence to enhance your experience:",
          "<ul><li><strong>Personalized Recommendations:</strong> AI analyzes your preferences to suggest relevant destinations and activities</li><li><strong>Dynamic Pricing:</strong> Algorithms optimize prices based on demand and availability</li><li><strong>Predictive Analytics:</strong> AI helps predict your travel needs and preferences</li><li><strong>Customer Support:</strong> Chatbots provide initial assistance and route complex queries to human agents</li></ul>",
          "All AI processing is designed to improve your experience while maintaining data privacy and security."
        ]
      },
      {
        "title": "3. Data Sharing",
        "content": [
          "We may share your data with:",
          "<ul><li><strong>Travel Partners:</strong> Hotels, airlines, and activity providers to fulfill your bookings</li><li><strong>Payment Processors:</strong> Secure payment platforms to process transactions</li><li><strong>Technology Partners:</strong> AI and analytics providers (with anonymized data when possible)</li><li><strong>Legal Authorities:</strong> When required by law or to protect our rights</li></ul>",
          "We never sell your personal data to third parties for marketing purposes."
        ]
      },
      {
        "title": "4. Your Rights",
        "content": [
          "Under GDPR, you have the following rights:",
          "<ul><li><strong>Access:</strong> Request a copy of your personal data</li><li><strong>Rectification:</strong> Correct inaccurate or incomplete data</li><li><strong>Erasure:</strong> Request deletion of your data (right to be forgotten)</li><li><strong>Portability:</strong> Receive your data in a structured, machine-readable format</li><li><strong>Objection:</strong> Object to processing based on legitimate interests</li><li><strong>Restriction:</strong> Limit how we process your data</li></ul>",
          "To exercise these rights, contact us at: geral@akmleva.pt"
        ]
      }
    ]
  },
  "termsPage": {
    "title": "General Terms and Conditions",
    "introduction": {
      "title": "Introduction",
      "content": [
        "Welcome to AKMLEVA, your trusted travel agency. These general terms and conditions govern the use of our services and establish the rights and obligations between AKMLEVA and our clients.",
        "By using our services, you agree to comply with these terms. We recommend that you read them carefully before making any reservation."
      ]
    },
    "sections": [
      {
        "title": "1. Object",
        "content": [
          "AKMLEVA is a travel agency registered in Portugal, specializing in organizing personalized trips and tourist experiences.",
          "Our services include trip planning, accommodation booking, transportation, tourist activities, and comprehensive travel support."
        ]
      },
      {
        "title": "2. AI Usage in Our Services",
        "content": [
          "AKMLEVA uses artificial intelligence technology to enhance your travel experience:",
          "<ul><li><strong>Personalized Recommendations:</strong> Our AI analyzes your preferences to suggest destinations and activities.</li><li><strong>Dynamic Pricing:</strong> AI algorithms help us offer competitive and fair prices.</li><li><strong>Customer Support:</strong> AI-powered chatbots provide 24/7 initial assistance.</li><li><strong>Trip Optimization:</strong> AI helps create efficient itineraries based on your interests and time.</li></ul>",
          "All AI decisions are supervised by our human experts to ensure quality and personalization."
        ]
      },
      {
        "title": "3. Booking Process",
        "content": [
