  "cancellationPage": {
    "hero": {
      "title": "Cancellation Policy",
      "subtitle": "Clear information for your security and planning."
    },
    "sectionPolicy": {
      "title": "Our Policy in Detail",
      "intro": "To ensure transparency, we detail the applicable conditions. We recommend careful reading.",
      "sections": [
        {
          "title": "General Conditions",
          "points": [
            "All requests must be made in writing via email.",
            "Calculation is based on the date of receipt of the request.",
            "Service and administrative fees are non-refundable."
          ]
        },
        {
          "title": "Deadlines and Fees (Land Packages)",
          "points": [
            "Cancellation more than 30 days in advance: 20% retention fee.",
            "Cancellation between 29 and 15 days: 50% retention fee.",
            "Cancellation less than 14 days: No refund."
          ],
          "periods": [
            {
              "period": "More than 30 days before",
              "fee": "20% retention fee"
            },
            {
              "period": "Between 29 and 15 days before",
              "fee": "50% retention fee"
            },
            {
              "period": "Less than 14 days before",
              "fee": "No refund"
            }
          ]
        },
        {
          "title": "Flights",
          "points": [
            "Flight cancellation policies are dictated by airlines and may be 100% non-refundable."
          ]
        }
      ],
      "important": {
        "title": "Important",
        "description": "In case of cancellation due to force majeure (pandemic, natural disasters, etc.), special conditions apply. Contact us for more information."
      }
    },
    "sectionHowTo": {
      "title": "How to Request a Cancellation",
      "steps": [
        {
          "title": "1. Contact Support",
          "description": "The fastest and safest way is through the official support email.",
          "icon": "mail"
        },
        {
          "title": "2. Provide Details",
          "description": "Please indicate your booking number, full name and reason for cancellation.",
          "icon": "info"
        },
        {
          "title": "3. Wait for Confirmation",
          "description": "You will receive an email confirmation with processing details.",
          "icon": "check"
        }
      ]
    },
    "sectionFaq": {
      "title": "Frequently Asked Questions",
      "questions": [
        {
          "q": "Can I cancel my booking online?",
          "a": "Currently, all cancellations must be processed through our email support to ensure security and accuracy."
        },
        {
          "q": "How long does the refund take?",
          "a": "Refunds are processed within 5 to 10 business days after cancellation confirmation, depending on the original payment method."
        },
        {
          "q": "Can I change instead of cancel?",
          "a": "Yes! It's often possible to change dates or destinations. Contact us to check available options for your booking."
        }
      ]
    },
    "needHelp": {
      "title": "Need Help?",
      "description": "Our team is here to help you with any questions about cancellations."
    },
    "contactSupport": {
      "title": "Contact Support",
      "description": "For cancellations or questions, contact us directly.",
      "button": "Send Email"
    },
    "myBookings": {
      "title": "My Bookings",
      "description": "Access your personal area to see all your bookings.",
      "button": "View Bookings"
    },
    "ui": {
      "loading": "Loading cancellation policy...",
      "refundTimeline": {
        "title": "Refund Timeline",
        "description": "See the table above to understand the applicable fees according to the cancellation period."
      },
      "howToHint": "The process is simple and automatic through your customer area."
    }
