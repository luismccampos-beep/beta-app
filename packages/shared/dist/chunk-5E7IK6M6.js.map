  "faq": {
    "badge": "FAQ",
    "title": "Frequently Asked Questions",
    "subtitle": "Everything you need to know about safety, data handling, and AI precision",
    "items": {
      "safety": {
        "q": "Is it safe to use?",
        "a": "Absolutely. The entire AI engine runs locally in your browser using WebAssembly. No data is transmitted to external servers, and no network requests are made during processing. Your preferences stay on your device at all times."
      },
      "dataSecurity": {
        "q": "How is my data protected?",
        "a": "All data is stored exclusively in your browser's local storage and is encrypted using device-level keys. We never collect, store, or transmit any personal information. You have full control and can delete everything with a single click."
      },
      "dataRetention": {
        "q": "How long is my data stored?",
        "a": "Your preferences are kept only in your browser's local storage for your convenience. They are automatically cleared after 7 days of inactivity, or you can delete them manually at any time from the Settings panel."
      },
      "dataSharing": {
        "q": "Is my data shared with third parties?",
        "a": "Never. Since all processing happens locally on your device, there is no server-side component that could share data. We do not use analytics trackers, advertising pixels, or any third-party data collection tools."
      },
      "precision": {
        "q": "How accurate are the AI recommendations?",
        "a": "Our local LLM cross-references your 5 preference dimensions (model, personalization, budget, dates, and review criteria) to generate highly relevant matches. Precision improves as you provide more detailed preferences."
      },
      "aiReliability": {
        "q": "Can I trust the AI suggestions?",
        "a": "The AI provides data-driven suggestions based on your inputs. All recommendations are transparent — you can review the reasoning behind each suggestion in the Review tab before taking any action."
      },
      "functionality": {
        "q": "What features are included?",
        "a": "The platform includes 5 preference tabs (AI Model, Personalization, Budget, Dates, Review), real-time search with local AI processing, import/export of preferences, eco-conscious options, and a fully responsive mobile experience."
      },
      "offline": {
        "q": "Does it work offline?",
        "a": "Yes. Once the page is loaded, the AI model runs entirely in your browser. You can configure preferences and run searches without an internet connection. Results are cached locally for later access."
      }
    }
  },
