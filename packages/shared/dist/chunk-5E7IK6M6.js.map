    "faq": {
      "badge": "FAQ",
      "title": "Frequently asked",
      "titleHighlight": "questions",
      "description": "Find answers to the most common questions about AKMLEVA CRM.",
      "items": [
        {
          "question": "What is AKMLEVA CRM?",
          "answer": "AKMLEVA CRM is a multi-tenant customer relationship management platform built specifically for travel agencies. It provides client management, lead tracking, visual sales pipeline, and booking management — all with complete data isolation between agencies using PostgreSQL Row-Level Security."
        },
        {
          "question": "How does multi-tenancy work?",
          "answer": "Each agency gets its own fully isolated environment. We use PostgreSQL Row-Level Security (RLS) with agency_id embedded in JWT tokens, ensuring every query is automatically scoped to the correct agency. This provides enterprise-grade security without the overhead or cost of separate databases."
        },
        {
          "question": "Can I use my own domain?",
          "answer": "Yes! On Professional and Enterprise plans you can configure custom domains and subdomains. Your clients will see your brand, not ours. We support subdomain-based access (agency.admin.akmleva.com) as well as fully custom domains with automatic SSL certificates."
        },
        {
          "question": "Is my data secure?",
          "answer": "Absolutely. We implement Row-Level Security at the database level, encrypt all data in transit (TLS 1.3) and at rest (AES-256), maintain GDPR compliance tools, and perform regular third-party security audits. All data is backed up automatically every day with 30-day retention."
        },
        {
          "question": "Can I upgrade or downgrade my plan?",
          "answer": "Yes, you can change your plan at any time from your agency dashboard. Upgrades take effect immediately with prorated billing. Downgrades apply at the end of the current billing period. There are no penalties, lock-in periods, or hidden cancellation fees."
        },
        {
          "question": "Do you offer a free trial?",
          "answer": "We offer a 14-day free trial for the Premium Plan with full access to all features. No credit card is required to start your trial. The Base Plan can be used without a trial period."
        },
        {
          "question": "What payment methods do you accept?",
          "answer": "We accept all major credit and debit cards (Visa, Mastercard, American Express), SEPA bank transfers for EU customers, and PayPal. All payments are processed securely through Stripe."
        }
      ]
    },
