    "userRights": {
      "title": "Your Rights as a Data Subject",
      "intro": "The GDPR grants you several powerful rights over your personal data. You can exercise them at any time by contacting us using the details in the “Data Controller” section.",
      "items": [
        { "right": "Right of Access", "description": "You may request confirmation that we process your personal data and obtain a copy, including purposes, categories, recipients and retention periods.", "important": true },
        { "right": "Right to Rectification", "description": "You may request the immediate correction of inaccurate or incomplete personal data." },
        { "right": "Right to Erasure (Right to be Forgotten)", "description": "You may request deletion of your personal data when it is no longer necessary, when you withdraw consent, or in other cases provided by the GDPR.", "important": true },
        { "right": "Right to Restriction of Processing", "description": "You may request temporary suspension of processing in certain circumstances (e.g., while verifying data accuracy or when you object to processing)." },
        { "right": "Right to Data Portability", "description": "You may receive your personal data in a structured, commonly used, machine-readable format and transmit it to another controller when processing is based on consent or contract." },
        { "right": "Right to Object", "description": "You may object to processing for direct marketing at any time, or for reasons related to your particular situation in cases of legitimate interest.", "important": true },
        { "right": "Right Not to be Subject to Automated Decisions", "description": "You have the right not to be subject to decisions based solely on automated processing, including profiling, that produce legal effects or similarly significantly affect you." }
      ],
      "footer": {
        "prefix": "To exercise any of these rights, just contact us via email",
        "email": "privacy@akmleva.pt",
        "suffix": ". We will respond within one month (extendable in complex cases)."
      }
    },
