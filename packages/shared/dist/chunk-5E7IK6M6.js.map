    "faqs": {
      "faq-001": {
        "question": "How can I cancel my booking?",
        "answer": "You can cancel your booking through the \"My Trips\" area in your profile or by contacting our support."
      },
      "faq-002": {
        "question": "What payment methods are accepted?",
        "answer": "We accept credit/debit cards (Visa, Mastercard, American Express), PayPal, and bank transfers."
      },
      "faq-003": {
        "question": "How can I change my booking details?",
        "answer": "Changes can be made through the \"My Trips\" area up to 24 hours before the departure date."
      },
      "faq-004": {
        "question": "What if I lose my voucher?",
        "answer": "You can re-download your voucher from the \"My Trips\" area or contact support to have it resent."
      },
      "faq-005": {
        "question": "How does the loyalty program work?",
        "answer": "Our loyalty program offers points for every booking. These can be exchanged for discounts on future trips."
      },
      "faq-006": {
        "question": "Can I make group bookings?",
        "answer": "Yes! For group bookings (10 or more people), we offer special conditions and a dedicated manager."
      }
    },
