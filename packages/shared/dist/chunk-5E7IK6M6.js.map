    "introduction": {
      "title": "Our privacy policy",
      "intro": "AKMLEVA is fully committed to protecting your privacy and personal data, in strict compliance with the General Data Protection Regulation (GDPR/EU 2016/679) and applicable legislation.",
      "trust": {
        "transparency": "Full transparency",
        "compliance": "GDPR compliance"
      }
    },
    "footer": {
      "effectiveSinceLabel": "Effective since:",
      "defaultEffectiveDate": "May 25, 2018",
      "statementPrefix": "This document is fully compliant with",
      "regulationName": "Regulation (EU) 2016/679",
      "statementSuffix": "(GDPR) and applicable national legislation.",
      "lastUpdatedLabel": "Last updated: {date}",
      "trustLine": "Commitment to transparency and protection of your rights",
      "branding": "Privacy Policy & Data Protection • AKMLEVA"
    },
    "dataProcessing": {
      "title": "Purposes of Personal Data Processing",
      "intro": "We process your personal data only for specific, explicit and legitimate purposes, in compliance with the GDPR.",
      "legalBasisLabel": "Legal basis",
      "purposes": [
        {
          "title": "Service Provision and Booking Management",
          "description": "Process travel bookings, accommodation, transportation and tourist activities, manage payments, issue travel documents and provide customer support during and after the trip.",
          "legalBasis": "Performance of a contract (Art. 6(1)(b) GDPR)",
          "basisColor": "blue"
        },
        {
          "title": "Compliance with Legal Obligations",
          "description": "Comply with tax, accounting and regulatory obligations, keep invoices and travel records for legal reasons.",
          "legalBasis": "Legal obligation (Art. 6(1)(c) GDPR)",
          "basisColor": "purple"
        },
        {
          "title": "Marketing and Personalized Communication",
          "description": "Send newsletters, promotions, personalized offers, satisfaction surveys and information about destinations similar to those previously booked.",
          "legalBasis": "Consent (Art. 6(1)(a) GDPR)",
          "basisColor": "green"
        },
        {
          "title": "Fraud Prevention and Security",
          "description": "Verify identity for bookings, prevent payment fraud, detect suspicious activities and protect systems and customer data.",
          "legalBasis": "Legitimate interests (Art. 6(1)(f) GDPR)",
          "basisColor": "amber"
        },
        {
          "title": "Service Improvement and Statistical Analysis",
          "description": "Analyze usage patterns, travel preferences and feedback to improve services, personalize offers and perform aggregated market studies.",
          "legalBasis": "Legitimate interests (Art. 6(1)(f) GDPR)",
          "basisColor": "amber"
        }
      ],
      "note": "We do not process your data for purposes incompatible with those described here without a new legal basis or your explicit consent."
    },
    "dataSecurity": {
      "title": "Data Security Measures",
      "intro": "We adopt appropriate and up-to-date technical and organizational measures to ensure a level of security proportional to the risk, in compliance with Article 32 of the GDPR.",
      "measures": [
        { "text": "TLS 1.3 encryption in transit and AES-256 at rest (databases and backups)", "important": true },
        { "text": "Multi-factor authentication (MFA) for all administrative access and critical systems", "important": true },
        { "text": "Role-based access control (RBAC) and least privilege principle" },
        { "text": "Real-time monitoring, intrusion detection (IDS/IPS) and audit logs" },
        { "text": "Mandatory annual training in data protection and cybersecurity for all employees" },
        { "text": "Independent security audits and periodic penetration testing" },
        { "text": "Incident response and disaster recovery plans regularly tested" }
      ],
      "note": "Despite the measures implemented, no system is 100% immune to risk. In case of a data breach, we will notify the supervisory authority and affected data subjects within the legal time limits."
    },
    "dataTypes": {
      "title": "Types of Personal Data Collected",
      "intro": "We collect only the data strictly necessary to provide contracted services and comply with legal obligations.",
      "headers": {
        "category": "Category",
        "examples": "Examples",
        "retention": "Retention period"
      },
      "categories": [
        { "category": "Identification Data", "examples": ["Full name", "Date of birth", "Identification number (ID/Passport)", "Nationality"], "retention": "5 years after last interaction", "retentionColor": "amber" },
        { "category": "Contact Data", "examples": ["Email address", "Phone number", "Postal address", "Contact preferences"], "retention": "3 years after last interaction or withdrawal of consent", "retentionColor": "green" },
        { "category": "Booking and Payment Data", "examples": ["Booking details (dates, destinations, contracted services)", "Payment info (last 4 digits, IBAN for transfers)", "Travel history"], "retention": "7 years (tax legal obligation)", "retentionColor": "red" },
        { "category": "Technical and Browsing Data", "examples": ["IP address", "Device and browser type", "Cookie data and similar technologies", "Approximate geolocation (with consent)"], "retention": "up to 26 months (or less if withdrawn)", "retentionColor": "green" },
        { "category": "Preferences and Profile Data", "examples": ["Travel preferences (destinations, accommodation type, activities)", "Feedback and reviews", "Loyalty program data (if applicable)"], "retention": "until consent withdrawal or 3 years after inactivity", "retentionColor": "amber" }
      ],
      "note": "Retention periods may be longer when required by law or shorter in case of exercising data subject rights.",
      "mobileHint": "Swipe to the right to see the full examples"
    },
    "dataCategories": {
      "title": "Categories of Personal Data Processed",
      "headers": {
        "category": "Category",
        "examples": "Examples",
        "retention": "Retention period"
      },
      "categories": [
        { "category": "Identification Data", "examples": ["Full name", "Email", "Phone number", "Identification document", "Date of birth"], "retention": "5 years after last interaction", "retentionSeverity": "medium" },
        { "category": "Contact Data", "examples": ["Postal address", "Phone number", "Email", "Communication preferences"], "retention": "3 years after last interaction", "retentionSeverity": "low" },
        { "category": "Booking Data", "examples": ["Trip details", "Accommodation preferences", "Payment information", "Booking history"], "retention": "7 years for tax purposes", "retentionSeverity": "high" },
        { "category": "Technical Data", "examples": ["IP address", "Cookies", "Browsing data", "Device used", "Approximate geolocation data"], "retention": "2 years or until consent withdrawal", "retentionSeverity": "low" }
