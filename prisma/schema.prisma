// ============================================
// AIRLINE PRODUCTS 
// ============================================

enum AirlineType {
  LOW_COST
  LEGACY
  REGIONAL
}

/// Airlines
model Airline {
  id        String  @id @default(uuid()) 
  name      String  @db.VarChar(255)
  code      String  @unique @db.VarChar(3) // "AA", "UA", etc.
  type      AirlineType @default(LEGACY) // low_cost, legacy, regional
  logo      String? @db.Text
  website   String? @db.VarChar(500)
  rating    Float?  @default(0) @db.Real
  published Boolean @default(true)

  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)

  flights Flight[]

  @@map("airlines")
}

/// Airport 
model Airport {
  id               String   @id @default(uuid()) 
  name             String   @db.VarChar(255)
  code             String   @unique @db.VarChar(3) // "JFK", "LAX", etc.
  city             String   @db.VarChar(100)
  country          String   @db.VarChar(100)
  latitude         Float?   @db.Real
  longitude        Float?   @db.Real
  createdAt        DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  loungeAvailable  Boolean  @default(false) @map("lounge_available")
  loungeDetails    Json?    @map("lounge_details") @db.JsonB
  priorityServices Json?    @map("priority_services") @db.JsonB

  departureFlights Flight[] @relation("DepartureAirport")
  arrivalFlights   Flight[] @relation("ArrivalAirport")

  routeOrigins     FlightRoute[] @relation("RouteOriginAirport")
  routeDests       FlightRoute[] @relation("RouteDestAirport")

  @@index([code])
  @@map("airports")
}

/// Flights 
model Flight {
  id                 String @id @default(uuid()) 
  airlineId          String @map("airline_id") 
  departureAirportId String @map("departure_airport_id") 
  arrivalAirportId   String @map("arrival_airport_id") 
  flightNumber       String @map("flight_number") @db.VarChar(20)
  agencyId           String? @map("agency_id") 

  // Schedule
  departureTime DateTime @map("departure_time") @db.Timestamp(3)
  arrivalTime   DateTime @map("arrival_time") @db.Timestamp(3)
  duration      Int       // seconds

  // Capacity & Availability
  totalSeats     Int @map("total_seats") @db.SmallInt
  availableSeats Int @map("available_seats") @db.SmallInt

  // Pricing
  basePrice Decimal  @map("base_price") @db.Decimal(10, 2)
  currency  Currency @default(BRL)
  // Status 
  status    String   @default("scheduled") @db.VarChar(20)
  published Boolean  @default(true)
  metadata  Json?    @db.JsonB

  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updatedat") @db.Timestamp(0)

  // Relationships
  agency          Agency?          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  airline         Airline          @relation(fields: [airlineId], references: [id])
  departureAirport Airport         @relation("DepartureAirport", fields: [departureAirportId], references: [id])
  arrivalAirport   Airport         @relation("ArrivalAirport", fields: [arrivalAirportId], references: [id])
  bookings         FlightBooking[]
  detail           FlightDetail?

  @@index([airlineId])
  @@index([agencyId])
  @@index([departureAirportId])
  @@index([arrivalAirportId])
  @@map("flights")
}

model FlightDetail {
  id        String   @id @default(uuid()) 
  flightId  String   @unique @map("flight_id") 
  overview  Json?    @db.JsonB
  pricing   Json?    @db.JsonB
  fareTiers Json?    @map("fare_tiers") @db.JsonB
  baggage   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updatedat") @db.Timestamp(0)

  flight Flight @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@map("flight_details")
}

/// FlightRoute — rotas aéreas (origem → destino) com distância e duração média
model FlightRoute {
  id        String @id @default(uuid()) 
  originId  String @map("origin_id") 
  destId    String @map("dest_id") 
  distanceKm Int?  @map("distance_km") 
  durationMin Int? @map("duration_min") 

  origin Airport @relation("RouteOriginAirport", fields: [originId], references: [id])
  dest   Airport @relation("RouteDestAirport", fields: [destId], references: [id])

  priceStats FlightPriceStatistic[]

  @@unique([originId, destId])
  @@index([originId])
  @@index([destId])
  @@map("flight_routes")
}

/// FlightPriceStatistic — estatísticas mensais de preços por rota
enum ConfidenceLevel {
  ALTA
  MEDIA
  BAIXA
}

model FlightPriceStatistic {
  id               String         @id @default(uuid()) 
  routeId          String         @map("route_id") 
  mes              Int            // 1-12
  precoMedio       Decimal?       @map("preco_medio") @db.Decimal(10, 2)
  precoMin         Decimal?       @map("preco_min") @db.Decimal(10, 2)
  precoMax         Decimal?       @map("preco_max") @db.Decimal(10, 2)
  precoMedioLowCost Decimal?      @map("preco_medio_low_cost") @db.Decimal(10, 2)
  precoMedioLegacy Decimal?       @map("preco_medio_legacy") @db.Decimal(10, 2)
  amostraCount     Int            @default(0) @map("amostra_count") 
  confianca        ConfidenceLevel @default(MEDIA)
  fonte            String?        @db.VarChar(100) // "kaggle", "scrape", "api", "manual"
  ano              Int            @default(2026)

  route FlightRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, mes, ano])
  @@index([routeId])
  @@index([mes])
  @@map("flight_price_statistics")
}


model ServiceDetail {
  id           String   @id @default(uuid()) 
  serviceId    String   @unique @map("service_id") 
  overview     Json?    @db.JsonB
  itineraries  Json?    @db.JsonB
  pricing      Json?    @db.JsonB
  availability Json?    @db.JsonB
  policies     Json?    @db.JsonB
  providerInfo Json?    @map("provider_info") @db.JsonB
  highlights   Json?    @db.JsonB
  included     Json?    @db.JsonB
  excluded     Json?    @db.JsonB
  images       Json?    @db.JsonB
  ratings      Float?   @db.Real
  createdAt    DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt    DateTime @updatedAt @map("updatedat") @db.Timestamp(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_details")
}

/// Cruise packages
model Cruise {
  id          String  @id @default(uuid()) 
  name        String  @unique @db.VarChar(255)
  operator    String  @db.VarChar(255)
  description String? @db.Text
  image       String? @db.Text
