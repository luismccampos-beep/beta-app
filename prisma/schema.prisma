/// Core user account with comprehensive profile
model User {
  id        String  @id @default(uuid()) 
  email     String  @unique @db.VarChar(255)
  password  String? @map("password_hash") @db.VarChar(255) // nullable for OAuth users
  name      String? @db.VarChar(255)
  username  String? @unique @db.VarChar(50)
  
  // Multi-tenancy
  agencyId  String? @map("agency_id") 

  // Profile
  avatar          String?   @db.Text
  avatarThumbnail String?   @map("avatar_thumbnail") @db.Text
  avatarUrl       String?   @map("avatar_url") @db.Text
  bio             String?   @db.Text
  location        String?   @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  birthDate       DateTime? @map("birth_date") @db.Date
  gender          String?   @db.VarChar(20) // "M", "F", "Other"
  taxId           String?   @map("tax_id") @db.VarChar(50) // NIF / VAT / Tax ID for invoicing

  // Address
  address    String? @db.VarChar(255)
  city       String? @db.VarChar(100)
  state      String? @db.VarChar(100)
  country    String? @db.VarChar(100)
  postalCode String? @map("postal_code") @db.VarChar(20)

  // Account Status
  status                 UserStatus @default(ACTIVE)
  role                   UserRole   @default(USER)
  joinDate               DateTime   @default(now()) @map("join_date")
  lastActive             DateTime   @updatedAt @map("last_active") @db.Timestamp(3)
  lastLogin              DateTime?  @map("last_login") @db.Timestamp(3)
  isVerified             Boolean    @default(false) @map("is_verified")
  emailVerified          Boolean    @default(false) @map("email_verified")
  phoneVerified          Boolean    @default(false) @map("phone_verified")
  emailVerifiedAt        DateTime?  @map("email_verified_at") @db.Timestamp(3)
  emailVerificationToken String?    @map("email_verification_token") @db.VarChar(255)
  passwordChangedAt      DateTime?  @map("password_changed_at") @db.Timestamp(3)

  // Security & 2FA
  twoFactorSecret           String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled          Boolean   @default(false) @map("two_factor_enabled")
  twoFactorBackupCode       Json  @default("[]") @map("two_factor_backup_code")
  forgotPasswordToken       String?   @map("forgot_password_token") @db.VarChar(255)
  forgotPasswordTokenExpiry DateTime? @map("forgot_password_token_expiry") @db.Timestamp(3)

  // User Preferences
  preferredCurrency Currency?       @default(BRL) @map("preferred_currency")
  preferredLanguage String?         @default("pt-PT") @map("preferred_language") @db.VarChar(10)
  travelFrequency   TravelFrequency @default(OCCASIONAL) @map("travel_frequency")
  timezone          String?         @db.VarChar(50)
  theme             String?         @db.VarChar(20) // "light", "dark", "system"

  // Legal Compliance (LGPD/GDPR)
  termsAccepted        Boolean   @default(false) @map("terms_accepted")
  privacyAccepted      Boolean   @default(false) @map("privacy_accepted")
  acceptedTermsDate    DateTime? @map("accepted_terms_date") @db.Timestamp(3)
  acceptedPrivacyDate  DateTime? @map("accepted_privacy_date") @db.Timestamp(3)
  marketingOptIn       Boolean   @default(false) @map("marketing_opt_in")
  dataProcessingOptIn  Boolean   @default(false) @map("data_processing_opt_in")
  dataRetentionConsent Boolean   @default(false) @map("data_retention_consent")
  gdprConsent          Boolean   @default(false) @map("gdpr_consent")

  // Profile Completion
  profileCompletion Int @default(0) @map("profile_completion") @db.SmallInt // 0-100
  experiencePoints  Int @default(0) @map("experience_points")
  streakCount       Int @default(0) @map("streak_count")

  // Account Status
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(3)
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamp(3)
  blockedAt     DateTime? @map("blocked_at") @db.Timestamp(3)
  blockedReason String?   @map("blocked_reason") @db.Text

  // Auth & Permissions (added for unified auth)
  isActive    Boolean  @default(true) @map("is_active")
  permissions Json @default("[]")

  // Relationships
  sessions                Session[]
  accounts                Account[] // OAuth accounts
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  twoFactorDevices        TwoFactorDevice[]
  notificationTokens      NotificationToken[]

  userPreferences      UserPreference?
  notificationSettings NotificationSetting?
  consentRecords       ConsentRecord[]

  trips                Trip[]
  bookings             Booking[]
  payments             PaymentTransaction[]
  paymentRecords       Payment[]
  reviews              Review[]
  favorites            Favorite[]
  destinationFavorites UserFavorite[]       @relation("UserDestinationFavorites")
  cartItems            CartItem[]
  vouchers             Voucher[]
  voucherUsages        VoucherUsage[]

  // Chat & Social
  aiConversations  AiConversation[]
  chatParticipants ChatParticipant[]
  aiChatMessages   ChatMessage[]
  friendsSent      UserFriend[]      @relation("UserFriendsInitiated")
  friendsReceived  UserFriend[]      @relation("UserFriendsReceived")

  notifications     Notification[]
  auditLogs         AuditLog[]
  articles          Article[]        @relation("UserArticles")
  moderatedArticles Article[]        @relation("ModeratedArticles")
  comments          ArticleComment[] @relation("UserComments")
  moderatedComments ArticleComment[] @relation("ModeratedComments")

  // Community
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  communityReactions CommunityReaction[]

  // Opposite relations added for diagnostics
  savedItineraries SavedItinerary[]
  chatMessages     RoomMessage[]
  quizAttempts     QuizAttempt[]
  loyaltyProgram   LoyaltyProgram?

  // AI Preferences Tracking
  preferenceEvents    PreferenceEvent[]
  responsePredictions ResponsePrediction[]

  // Multi-tenancy relationship
  agency Agency? @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("users")
}

// ============================================
// COMMUNITY (Authenticated-only)
// ============================================

enum CommunityReactionType {
  LIKE
}

model CommunityPost {
  id       String @id @default(uuid())
  authorId String @map("author_id")

  title String @db.VarChar(255)
  body  String @db.Text
  tags  Json   @default("[]")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(3)

  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  CommunityComment[]
  reactions CommunityReaction[]

  @@index([authorId])
  @@index([createdAt])
  @@map("community_posts")
}

model CommunityComment {
  id       String @id @default(uuid())
  postId   String @map("post_id")
  authorId String @map("author_id")
  parentId String? @map("parent_id")

  body String @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(3)

  post   CommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent CommunityComment? @relation("CommunityCommentThread", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  replies CommunityComment[] @relation("CommunityCommentThread")

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@index([parentId])
  @@map("community_comments")
}

model CommunityReaction {
  id     String @id @default(uuid())
  postId String                @map("post_id")
  userId String                @map("user_id")
  type   CommunityReactionType @default(LIKE)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
  @@map("community_reactions")
}

// ============================================
// MULTI-TENANCY MODELS
// ============================================

/// Agency for multi-tenant SaaS architecture
model Agency {
  id              String  @id @default(uuid()) 
  name            String  @db.VarChar(255)
  slug            String  @unique @db.VarChar(100) // For subdomains
  domain          String? @unique @db.VarChar(255) // For custom domains
  logoUrl         String? @map("logo_url") @db.Text
  primaryColor    String  @default("#3B82F6") @map("primary_color") @db.VarChar(7)
  secondaryColor  String  @default("#10B981") @map("secondary_color") @db.VarChar(7)
  accentColor     String  @default("#F59E0B") @map("accent_color") @db.VarChar(7)
  plan            AgencyPlan @default(STARTER)
  status          AgencyStatus @default(ACTIVE)
  settings        Json     @default("{}") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  trialEndsAt     DateTime? @map("trial_ends_at") @db.Timestamp(3)
  subscriptionId  String?  @map("subscription_id") @db.VarChar(255) // Stripe subscription ID
  maxUsers        Int      @default(5) @map("max_users")
  maxClients      Int      @default(100) @map("max_clients")
  features        Json     @default("[]") @db.JsonB // Feature flags

  // Relationships
  users    User[]
  clients  Client[]
  bookings Booking[]
  leads    Lead[]
  flights  Flight[]
  hotels   Hotel[]
  cruises  Cruise[]
  packages Package[]

  @@index([domain])
  @@map("agencies")
}

enum AgencyPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// CRM MODELS (Multi-tenant)
// ============================================

/// Client model for agency customer management
model Client {
  id        String   @id @default(uuid()) 
  agencyId  String   @map("agency_id") 
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  document  String?  @db.VarChar(50) // CPF, Passport, etc.
  birthDate DateTime? @map("birth_date") @db.Date
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  country   String?  @db.VarChar(100)
  notes     String?  @db.Text
  tags      Json @default("[]")
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relationships
  bookings Booking[] @relation("ClientBookings")
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([email])
  @@map("clients")
}

/// Lead model for sales pipeline management
model Lead {
  id         String     @id @default(uuid()) 
  agencyId   String     @map("agency_id") 
  name       String     @db.VarChar(255)
  email      String?    @db.VarChar(255)
  phone      String?    @db.VarChar(20)
  source     String?    @db.VarChar(100) // Website, Referral, Social Media
  status     LeadStatus @default(NEW)
  priority   LeadPriority @default(MEDIUM)
  value      Decimal?   @db.Decimal(10, 2)
  notes      String?    @db.Text
  tags       Json   @default("[]")
  metadata   Json?      @db.JsonB
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relationships
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([status])
  @@index([email])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// OAuth accounts for Auth.js v5 compatibility
model Account {
  id                String  @id @default(uuid()) 
  userId            String  
  type              String  @db.VarChar(50) // "oauth", "email", "credentials"
  provider          String  @db.VarChar(50) // "google", "github", "credentials"
  providerAccountId String  @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Email verification tokens
model EmailVerificationToken {
  tokenId   String   @id @default(uuid()) 
  userId    String   
  token     String   @unique @db.VarChar(255)
  email     String   @db.VarChar(255)
  expiresAt DateTime @db.Timestamp(3)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

/// Password reset tokens
model PasswordResetToken {
  id        String    @id @default(uuid()) 
  userId    String    
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @db.Timestamp(3)
  usedAt    DateTime? @db.Timestamp(3)
  createdAt DateTime  @default(now()) @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

/// Session management for multi-device support with enhanced security
model Session {
  id           String  @id @default(uuid()) 
  userId       String  
  token        String  @unique @db.VarChar(500)
  refreshToken String? @unique @db.VarChar(500)
  deviceInfo   Json?   @db.JsonB // { userAgent, ip, deviceType, browser, os }

  // SECURITY: Device fingerprinting for token binding
  deviceFingerprint String? @map("device_fingerprint") @db.VarChar(255) // Hash of device characteristics
  ipAddress         String? @map("ip_address") @db.VarChar(45) // IPv6 compatible
  ipHash            String? @map("ip_hash") @db.VarChar(64) // SHA-256 hash of IP

  // SECURITY: Token rotation tracking
  refreshTokenFamily String? @map("refresh_token_family") @db.VarChar(255) // UUID for token family
  tokenSequence      Int     @default(0) @map("token_sequence") // Incremental counter for rotation

  // SECURITY: Session lifecycle management
  expiresAt      DateTime  @db.Timestamp(3)
  createdAt      DateTime  @default(now()) @db.Timestamp(0)
  lastUsedAt     DateTime  @updatedAt @db.Timestamp(0)
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamp(0) // For idle timeout
  revokedAt      DateTime? @db.Timestamp(3)
  isRevoked      Boolean   @default(false) @map("is_revoked")

  // Security events tracking
  securityFlags Json @default("[]") @map("security_flags") // ["ip_changed", "suspicious_activity"]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([refreshTokenFamily])
  @@index([expiresAt])
  @@index([deviceFingerprint])
  @@map("sessions")
}

/// API Keys for service-to-service authentication
model ApiKey {
  id        String @id @default(uuid()) 
  name      String @db.VarChar(255) // Human-readable name for the key
  keyHash   String @unique @map("key_hash") @db.VarChar(255) // bcrypt hash of the API key
  keyPrefix String @map("key_prefix") @db.VarChar(8) // First 8 chars for identification

  // Ownership and scope
  userId      String?  // Optional: linked to user for audit
  serviceName String  @db.VarChar(100) // e.g., "ml-service", "payment-gateway"

  // Permissions
  permissions Json @default("[]") // ["read:bookings", "write:payments"]
  scopes      Json @default("[]") // ["service", "admin", "webhook"]

  // Security settings
  allowedIps Json @default("[]") @map("allowed_ips") // IP whitelist
  rateLimit  Int      @default(1000) @map("rate_limit") // Requests per hour

  // Lifecycle
  expiresAt  DateTime? @db.Timestamp(3)
  lastUsedAt DateTime? @db.Timestamp(3)
  createdAt  DateTime  @default(now()) @db.Timestamp(0)
  revokedAt  DateTime? @db.Timestamp(3)
  isActive   Boolean   @default(true) @map("is_active")

  // Audit
  createdBy    String? @map("created_by") 
  revokedBy    String? @map("revoked_by") 
  revokeReason String? @map("revoke_reason") @db.Text

  @@index([keyHash])
  @@index([serviceName])
  @@index([userId])
  @@index([isActive, expiresAt])
  @@map("api_keys")
}

/// Two-factor authentication devices
model TwoFactorDevice {
  id        String   @id @default(uuid()) 
  userId    String   
  deviceId  String   @db.VarChar(100)
  name      String   @db.VarChar(255) // "My Phone", "Laptop", etc.
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId])
  @@map("two_factor_devices")
}

/// Push notification tokens for mobile/web
model NotificationToken {
  id         String   @id @default(uuid()) 
  userId     String   
  token      String   @unique @db.VarChar(500)
  type       String   @db.VarChar(20) // "web", "ios", "android"
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamp(0)
  lastUsedAt DateTime @updatedAt @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("notification_tokens")
}

/// User friends and social relations
model UserFriend {
  id        String   @id @default(uuid()) 
  userId    String   @map("user_id") 
  friendId  String   @map("friend_id") 
  status    String   @default("PENDING") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user   User @relation("UserFriendsInitiated", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("UserFriendsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("user_friends")
}

/// User travel and app preferences
model UserPreference {
  id     String @id @default(uuid()) 
  userId String @unique @map("user_id") 

  // Notification preferences
  emailNotifications Boolean @default(true) @map("email_notifications")
  smsNotifications   Boolean @default(false) @map("sms_notifications")
  pushNotifications  Boolean @default(true) @map("push_notifications")
  promotionalEmails  Boolean @default(true) @map("promotional_emails")

  // Travel preferences
  preferredAccommodationType Json?    @map("preferred_accommodation_type") @db.JsonB // ["hotel", "hostel", "airbnb"]
  budgetRangeMin             Decimal? @map("budget_range_min") @db.Decimal(10, 2)
  budgetRangeMax             Decimal? @map("budget_range_max") @db.Decimal(10, 2)

  // Quiz-based preferences (for travel recommendations)
  favoriteDestinationTypes Json @default("[]") @map("favorite_destination_types")
  favoriteActivities       Json @default("[]") @map("favorite_activities")
  travelStyle              String?  @map("travel_style") @db.VarChar(50)
  budgetRange              String?  @map("budget_range") @db.VarChar(50)
  accommodationPreference  String?  @map("accommodation_preference") @db.VarChar(100)
  tripDuration             String?  @map("trip_duration") @db.VarChar(50)
  groupSize                String?  @map("group_size") @db.VarChar(50)
  pacePreference           String?  @map("pace_preference") @db.VarChar(50)
  cuisinePreferences       Json @default("[]") @map("cuisine_preferences")
  dietaryRestrictions      Json @default("[]") @map("dietary_restrictions")

  // Booking preferences
  autoAcceptBestPrice Boolean  @default(false) @map("auto_accept_best_price")
  receivePriceAlerts  Boolean  @default(true) @map("receive_price_alerts")
  priceAlertThreshold Decimal? @map("price_alert_threshold") @db.Decimal(3, 2)

  // Display preferences
  darkMode        Boolean @default(false) @map("dark_mode")
  temperatureUnit String? @map("temperature_unit") @db.VarChar(1) // 'C' or 'F'
  distanceUnit    String? @map("distance_unit") @db.VarChar(2) // 'km' or 'mi'

  // AI Assistant Preferences
  aiSettings Json? @map("ai_settings") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// (Redundant settings models removed to match SQL schema)

/// Consent records for LGPD/GDPR compliance
model ConsentRecord {
  id          String   @id @default(uuid()) 
  userId      String   
  consentType String   @db.VarChar(100) // "terms", "privacy", "marketing", "analytics"
  version     String   @db.VarChar(20)
  granted     Boolean
  grantedAt   DateTime @db.Timestamp(3)
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text

  createdAt DateTime @default(now()) @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_records")
}

/// Audit trail for security & compliance
model AuditLog {
  id        String  @id @default(uuid()) 
  userId    String? 
  action    String  @db.VarChar(100) // "user.login", "booking.created", etc.
  entity    String  @db.VarChar(50) // "User", "Booking"
  entityId  String? 
  changes   Json?   @db.JsonB
  metadata  Json?   @db.JsonB
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamp(0)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

/// Logs de pesquisas de lugares (monitorização de performance das chamadas externas)
