  dicas             Json?    @db.JsonB
  tags              Json?    @db.JsonB
  wikivoyageUrl     String?  @map("wikivoyage_url") @db.VarChar(500)
  wikipediaResumo   String?  @map("wikipedia_resumo") @db.Text
  wikipediaUrl      String?  @map("wikipedia_url") @db.VarChar(500)
  climaTempo        Json?    @map("clima_tempo") @db.JsonB
  custoDeVida       Json?    @map("custo_de_vida") @db.JsonB
  transporte        Json?    @db.JsonB
  latitude          Float?   @db.Real
  longitude         Float?   @db.Real
  imagemUrl         String?  @map("imagem_url") @db.VarChar(500)
  imagemQuery       String?  @map("imagem_query") @db.VarChar(255)
  hotelCount        Int      @default(0) @map("hotel_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  hotels   WvHotel[]
  flights  WvFlight[]
  listings WvListing[]

  @@index([pais, nome])
  @@index([slug])
  @@index([lang, nome])
  @@index([iata])
  @@index([iata, lang, hotelCount])
  @@map("wv_destinations")
}

model WvHotel {
  id            Int      @id
  destinoId     Int      @map("destino_id")
  nome          String   @db.VarChar(300)
  estrelas      Int      @default(3)
  precoPorNoite Int      @map("preco_por_noite")
  comodidades   Json     @default("[]") @db.JsonB
  fonte         String?  @db.VarChar(40)
  latitude      Float?   @db.Real
  longitude     Float?   @db.Real
  description   String?  @db.Text
  imageUrl      String?  @map("image_url") @db.Text
  googlePlaceId String?  @map("google_place_id") @db.VarChar(128)
  wikidataId    String?  @map("wikidata_id") @db.VarChar(32)
  tipoAlojamento String? @map("tipo_alojamento") @db.VarChar(40)
  createdAt     DateTime @default(now()) @map("created_at")

  destino  WvDestination   @relation(fields: [destinoId], references: [id], onDelete: Cascade)
  amenities  WvHotelAmenity[]
  reviews  WvHotelReview[]

  @@index([destinoId])
  @@index([destinoId, precoPorNoite])
  @@index([latitude, longitude])
  @@map("wv_hotels")
}

/// Avaliações MVP (utilizadores da app; sem stars OSM centralizados).

/// Amenidades normalizadas do WvHotel (extraídas do JSON comodidades)
model WvHotelAmenity {
  id        Int      @id @default(autoincrement())
  wvHotelId Int      @map("wv_hotel_id")
  name      String   @db.VarChar(100)

  wvHotel WvHotel @relation(fields: [wvHotelId], references: [id], onDelete: Cascade)

  @@unique([wvHotelId, name])
  @@index([wvHotelId])
  @@index([name])
  @@map("wv_hotel_amenities")
}

model WvHotelReview {
  id         String   @id @default(cuid())
  hotelId    Int      @map("hotel_id")
  rating     Int
  comment    String?  @db.Text
  authorName String?  @map("author_name") @db.VarChar(120)
  createdAt  DateTime @default(now()) @map("created_at")

  hotel WvHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, createdAt])
  @@map("wv_hotel_reviews")
}

model WvFlight {
  id              Int      @id
  origem          String   @db.VarChar(8)
  destinoId       Int      @map("destino_id")
  destinoIata     String?  @map("destino_iata") @db.VarChar(8)
  preco           Int
  duracaoMinutos  Int      @map("duracao_minutos")
  companhia       String   @db.VarChar(120)
  cabinClass      String   @default("economy") @map("cabin_class") @db.VarChar(32)
  escalas         Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  destino WvDestination @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  @@index([origem, destinoId])
  @@index([origem, destinoIata])
  @@index([destinoIata])
  @@map("wv_flights")
}

/// Listagens Wikivoyage (sleep, eat, see, …)
model WvListing {
  id        String   @id @default(cuid())
  destinoId Int?     @map("destino_id")
  article   String   @db.VarChar(255)
  type      String   @db.VarChar(32)
  title     String   @db.Text
  address   String?  @db.Text
  price     String?  @db.Text
  latitude  Float?   @db.Real
  longitude Float?   @db.Real
  url       String?  @db.Text
  payload   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  destino WvDestination? @relation(fields: [destinoId], references: [id], onDelete: SetNull)

  @@index([destinoId, type])
  @@index([article, type])
  @@map("wv_listings")
}

/// Custo de vida por cidade (CSV Numbeo/Kaggle)
model ColCity {
  id        String   @id @default(cuid())
  city      String   @db.VarChar(200)
  country   String   @db.VarChar(120)
  cityKey   String   @unique @map("city_key") @db.VarChar(255)
  indices   Json     @db.JsonB
  budgets   Json?    @db.JsonB
  rawPrices Json?    @map("raw_prices") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  @@index([country, city])
  @@map("col_cities")
}

/// Índice de custo de vida por país
model ColCountryIndex {
  id        String   @id @default(cuid())
  country   String   @unique @db.VarChar(120)
  colIndex  Float    @map("col_index") @db.Real
  rentIndex Float?   @map("rent_index") @db.Real
  payload   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  @@map("col_country_indices")
}

model CarRentalCompany {
  id        String      @id @default(cuid())
  name      String      @db.VarChar(100)
  slug      String      @unique @db.VarChar(100)
  logoUrl   String?     @db.Text
  createdAt DateTime    @default(now()) @map("createdat") @db.Timestamp(0)

  cars      RentalCar[]

  @@map("car_rental_companies")
}

model RentalCar {
  id           String          @id @default(cuid())
  countryCode  String          @map("country_code") @db.VarChar(8)
  category     String          @db.VarChar(50)
  modelName    String          @map("model_name") @db.VarChar(100)
  imageUrl     String          @map("image_url") @db.VarChar(500)
  pricePerDay  Decimal         @map("price_per_day") @db.Decimal(10, 2)
  currency     String          @default("USD") @db.VarChar(5)
  transmission String          @db.VarChar(20)
  fuelType     String          @map("fuel_type") @db.VarChar(20)
  doors        Int
  passengers   Int
  bags         Int
  companyId    String          @map("company_id")
  company      CarRentalCompany @relation(fields: [companyId], references: [id])

  @@index([countryCode])
  @@index([category])
  @@index([companyId])
  @@map("rental_cars")
}

