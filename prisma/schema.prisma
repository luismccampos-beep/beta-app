/// Destination catalog
model Destination {
  id          String  @id @default(uuid()) 
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255)
  country     String  @db.VarChar(100)
  countryCode String? @map("country_code") @db.VarChar(2)
  city        String  @db.VarChar(100)
  region      String? @db.VarChar(100)
  postalCode  String? @map("postal_code") @db.VarChar(20)

  // Description
  description      String? @db.Text
  shortDescription String? @map("short_description") @db.VarChar(500)
  longDescription  String? @map("long_description") @db.Text
  imageUrl         String? @map("image_url") @db.VarChar(500)
  images           Json?   @db.JsonB

  // Location (GIS)
  locationLatLon Json?    @map("location_latlon") @db.JsonB
  latitude       Decimal? @db.Decimal(10, 8)
  longitude      Decimal? @db.Decimal(11, 8)
  timezone       String?  @db.VarChar(50)
  altitudeMeters Int?     @map("altitude_meters") 

  // Pricing
  pricePerDay      Float?   @map("price_per_day") @db.Real
  pricePerNight    Float?   @map("price_per_night") @db.Real
  currency         Currency @default(BRL)
  priceReliability Float?   @map("price_reliability") @db.Real

  // Ratings & Reviews
  rating                   Decimal? @default(0) @db.Decimal(3, 2)
  reviewsCount             Int      @default(0) @map("reviews_count")
  recommendationPercentage Int      @default(0) @map("recommendation_percentage")

  // Travel information
  climateInfo             String?            @map("climate_info") @db.Text
  seasonality             Seasonality        @default(TEMPERATE)
  bestTimeToVisit         String?            @map("best_time_to_visit") @db.VarChar(100)
  worstTimeToVisit        String?            @map("worst_time_to_visit") @db.VarChar(100)
  averageTemperatureMin   Decimal?           @map("average_temperature_min") @db.Decimal(5, 2)
  averageTemperatureMax   Decimal?           @map("average_temperature_max") @db.Decimal(5, 2)
  visaRequirements        String?            @map("visa_requirements") @db.Text
  visaRequirementsForNats Json?              @map("visa_requirements_for_nationalities") @db.JsonB
  primaryLanguage         String?            @map("primary_language") @db.VarChar(100)
  languagesSpoken         Json?              @map("languages_spoken") @db.JsonB
  safetyRating            Int                @default(5) @map("safety_rating") 
  crimeRatePercentage     Decimal?           @map("crime_rate_percentage") @db.Decimal(5, 2)
  accessibilityLevel      AccessibilityLevel @default(PARTIAL) @map("accessibility_level")

  // Categories & Tags
  category     DestinationCategory @default(CITY)
  tags         Json            @default("[]")
  travelStyles Json?               @map("travel_styles") @db.JsonB

  // AI-enhanced data
  aiDescription     String?  @map("ai_description") @db.Text
  aiRecommendations Json?    @map("ai_recommendations") @db.JsonB
  aiLocalTips       Json?    @map("ai_local_tips") @db.JsonB
  popularityScore   Decimal? @default(0) @map("popularity_score") @db.Decimal(5, 2)
  trendingScore     Decimal? @default(0) @map("trending_score") @db.Decimal(5, 2)
  seasonalityData   Json?    @map("seasonality_data") @db.JsonB

  // Structured data for itineraries and other dynamic content
  structuredData Json? @map("structured_data") @db.JsonB

  // SEO
  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.VarChar(500)
  metaKeywords    String? @map("meta_keywords") @db.VarChar(500)

  // Moderation & Status
  isVerified       Boolean @default(false) @map("is_verified")
  isPublished      Boolean @default(true) @map("is_published")
  isActive         Boolean @default(true) @map("is_active")
  isFeatured       Boolean @default(false) @map("is_featured")
  isPopular        Boolean @default(false) @map("is_popular")
  isTrending       Boolean @default(false) @map("is_trending")
  moderationStatus String? @map("moderation_status") @db.VarChar(50)

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  publishedAt DateTime? @map("published_at") @db.Timestamp(3)
  indexedAt   DateTime? @map("indexed_at") @db.Timestamp(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(3)

  // Relationships
  attractions Attraction[]
  bookings    Booking[]
  reviews     Review[]     @relation("DestinationReviews")

  activities      Activity[]
  accommodations  Accommodation[]
  transportations Transportation[]

  articles         Article[]
  blogPosts        ArticleDestination[]
  savedItineraries SavedItinerary[]
  services         Service[]
  userFavorites    UserFavorite[]
  tripDestinations TripDestination[]

  @@index([country, city])
  @@index([rating])
  @@index([slug])
  @@map("destinations")
}

/// Points of interest
model Attraction {
  id            String @id @default(uuid()) 
  destinationId String @map("destination_id") 

  // Basic info
  name        String  @db.VarChar(255)
  slug        String? @unique @db.VarChar(255)
  description String? @db.Text
  category    String  @db.VarChar(100)
  subCategory String? @map("sub_category") @db.VarChar(100)

  // Location
  address        String   @db.Text
  postalCode     String?  @map("postal_code") @db.VarChar(20)
  locationLatLon Json?    @map("location_latlon") @db.JsonB
  latitude       Decimal? @db.Decimal(10, 8)
  longitude      Decimal? @db.Decimal(11, 8)

  // Details
  priceCurrency Currency? @default(BRL) @map("price_currency")
  priceAmount   Decimal?  @map("price_amount") @db.Decimal(10, 2)
  priceRange    String?   @map("price_range") @db.VarChar(10)
  freeEntry     Boolean?  @default(false) @map("free_entry")

  // Hours
  openingHours Json?    @map("opening_hours") @db.JsonB
  isOpen24h    Boolean? @default(false) @map("is_open_24h")

  // Contact & External
  contactInfo Json?   @map("contact_info") @db.JsonB
  websiteUrl  String? @map("website_url") @db.VarChar(500)
  bookingUrl  String? @map("booking_url") @db.VarChar(500)

  // Media
  imageUrl String? @map("image_url") @db.VarChar(500)
  images   Json?   @db.JsonB

  // Ratings & Reviews
  rating       Decimal? @default(0) @db.Decimal(3, 2)
  reviewsCount Int      @default(0) @map("reviews_count")

  // Features
  accessibilityFeatures  Json? @map("accessibility_features") @db.JsonB
  amenities              Json? @db.JsonB
  acceptedPaymentMethods Json? @map("accepted_payment_methods") @db.JsonB

  // Information
  averageVisitDurationMinutes Int?    @map("average_visit_duration_minutes")
  bestTimeToVisit             String? @map("best_time_to_visit") @db.VarChar(100)
  languagesGuideAvailable     Json?   @map("languages_guide_available") @db.JsonB

  // Moderation
  isVerified  Boolean @default(false) @map("is_verified")
  isPublished Boolean @default(true) @map("is_published")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  // Relationships
  destination Destination         @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  reviews     Review[]
  blogPosts   ArticleAttraction[]

  @@index([destinationId])
  @@map("attractions")
}

