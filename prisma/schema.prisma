// ============================================
// SHOPPING CART  
// ============================================

/// Shopping cart items
model CartItem {
  id       String @id @default(uuid()) 
  userId   String 
  itemType String @db.VarChar(50) // "flight", "hotel", "service", "cruise"
  itemId   String  // reference to the actual product

  // Details
  quantity   Int       @default(1) @db.SmallInt
  checkIn    DateTime? @db.Date
  checkOut   DateTime? @db.Date
  passengers Json?     @db.JsonB // passenger details

  // Pricing
  price    Decimal  @db.Decimal(10, 2)
  currency Currency @default(BRL)

  // Metadata
  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  expiresAt DateTime @db.Timestamp(3) // cart items expire

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemType])
  @@map("cart_items")
}

// ============================================
// BOOKINGS (ALL TYPES)
// ============================================

/// Generic booking model (all types: flight, hotel, service, cruise, etc.)
model Booking {
  id                       String  @id @default(uuid()) 
  userId                   String  @map("user_id") 
  agencyId                 String? @map("agency_id") 
  clientId                 String? @map("client_id") 
  destinationId            String? @map("destination_id") 
  tripId                   String? @map("trip_id") 
  tripDestinationId        String? @map("trip_destination_id") 
  bookingReference         String  @unique @map("booking_reference") @db.VarChar(50)
  supplierBookingReference String? @map("supplier_booking_reference") @db.VarChar(100)

  // Dates
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  checkInTime  String?  @map("check_in_time") @db.VarChar(10)
  checkOutTime String?  @map("check_out_time") @db.VarChar(10)

  // Guests
  adults   Int @default(1) @db.SmallInt
  children Int @default(0) @db.SmallInt
  infants  Int @default(0) @db.SmallInt

  // Pricing
  pricePerNight  Float?   @map("price_per_night") @db.Real
  subtotal       Float    @map("subtotal") @db.Real
  taxAmount      Float?   @default(0) @map("tax_amount") @db.Real
  discountAmount Float?   @default(0) @map("discount_amount") @db.Real
  totalPrice     Float    @map("total_price") @db.Real
  currency       Currency @default(BRL)

  // Status
  bookingStatus BookingStatus @default(PENDING) @map("booking_status")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  // Payment
  paymentMethod        PaymentMethod @map("payment_method")
  paymentIntentId      String?       @map("payment_intent_id") @db.VarChar(255)
  paymentTransactionId String?       @map("payment_transaction_id") @db.VarChar(255)
  lastPaymentAttempt   DateTime?     @map("last_payment_attempt") @db.Timestamp(3)

  // Cancellation
  cancellationReason String?   @map("cancellation_reason") @db.VarChar(255)
  cancellationDate   DateTime? @map("cancellation_date") @db.Timestamp(3)
  refundAmount       Float?    @map("refund_amount") @db.Real
  refundDate         DateTime? @map("refund_date") @db.Timestamp(3)

  // Contact
  guestEmail            String  @map("guest_email") @db.VarChar(255)
  guestPhone            String? @map("guest_phone") @db.VarChar(20)
  emergencyContactName  String? @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String? @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactEmail String? @map("emergency_contact_email") @db.VarChar(255)

  // Special requests
  specialRequests           String? @map("special_requests") @db.Text
  dietaryPreferences        String? @map("dietary_preferences") @db.VarChar(255)
  accessibilityRequirements String? @map("accessibility_requirements") @db.Text

  // Correspondence
  confirmationSent   Boolean   @default(false) @map("confirmation_sent")
  confirmationSentAt DateTime? @map("confirmation_sent_at") @db.Timestamp(3)
  reminderSent       Boolean   @default(false) @map("reminder_sent")
  reminderSentAt     DateTime? @map("reminder_sent_at") @db.Timestamp(3)

  // Timestamps
  createdAt    DateTime  @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt    DateTime  @updatedAt @map("updatedat") @db.Timestamp(0)
  checkedInAt  DateTime? @map("checked_in_at") @db.Timestamp(3)
  checkedOutAt DateTime? @map("checked_out_at") @db.Timestamp

  // Relationships
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency          Agency?           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client          Client?           @relation("ClientBookings", fields: [clientId], references: [id], onDelete: SetNull)
  destination     Destination?      @relation(fields: [destinationId], references: [id])
  trip            Trip?             @relation(fields: [tripId], references: [id])
  tripDestination TripDestination?  @relation("TripDestinationBookings", fields: [tripDestinationId], references: [id])
  payments        PaymentTransaction[]
  paymentRecords  Payment[]
  reviews         Review[]           @relation("ReviewBooking")
  flightBookings  FlightBooking[]
  hotelBookings   HotelBooking[]
  cruiseBookings  CruiseBooking[]
  transferBookings TransferBooking[]
  bookingHistory  BookingHistory[]
  serviceBookings ServiceBooking[]

  @@index([userId])
  @@index([agencyId])
  @@index([clientId])
  @@index([destinationId])
  @@index([tripId])
  @@index([bookingStatus, paymentStatus])
  @@index([tripDestinationId])
  @@map("bookings")
}

