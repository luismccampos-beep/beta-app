/// Transfer bookings
model TransferBooking {
  id         String   @id @default(uuid()) 
  bookingId  String   
  transferId String   
  pickupTime DateTime @db.Timestamp(3)
  price      Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  transfer Transfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@map("transfer_bookings")
}

/// Booking history for auditing
model BookingHistory {
  id        String   @id @default(uuid()) 
  bookingId String   
  status    String   @db.VarChar(50)
  reason    String?  @db.Text
  changes   Json?    @db.JsonB // what changed
  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@map("booking_history")
}

// ============================================
// PAYMENTS & TRANSACTIONS
// ============================================

/// Payment transactions for bookings
model PaymentTransaction {
  id        String @id @default(uuid()) 
  bookingId String @map("booking_id") 
  userId    String @map("user_id") 

  // Transaction info
  transactionId        String        @unique @map("transaction_id") @db.VarChar(100)
  gatewayTransactionId String?       @map("gateway_transaction_id") @db.VarChar(255)
  amount               Decimal       @db.Decimal(12, 2)
  currency             Currency      @default(BRL)
  paymentMethod        PaymentMethod @map("payment_method")

  // Status
  status        PaymentStatus @map("status")
  failureReason String?       @map("failure_reason") @db.VarChar(255)
  errorCode     String?       @map("error_code") @db.VarChar(100)
  errorMessage  String?       @map("error_message") @db.Text

  // Card info (if applicable)
  cardLastFour String? @map("card_last_four") @db.VarChar(4)
  cardBrand    String? @map("card_brand") @db.VarChar(50)

  // Refund info
  refundable   Boolean @default(false) 
  refundAmount String? @map("refund_amount") @db.VarChar(20)
  refundReason String? @map("refund_reason") @db.VarChar(255)

  // Provider data
  providerData Json? @map("provider_data") @db.JsonB

  // Timestamps
  createdAt   DateTime  @default(now()) @map("createdat") @db.Timestamp(0)
  processedAt DateTime? @map("processed_at") @db.Timestamp(3)
  refundedAt  DateTime? @map("refunded_at") @db.Timestamp(3)
  updatedAt   DateTime  @updatedAt @map("updatedat") @db.Timestamp(0)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([transactionId])
  @@map("payment_transactions")
}

/// Payment model (mirror of PaymentTransaction for legacy code — consider migrating to PaymentTransaction)
model Payment {
  id        String @id @default(uuid()) 
  bookingId String @map("booking_id") 
  userId    String @map("user_id") 

  // Transaction info
  transactionId        String        @unique @map("transaction_id") @db.VarChar(100)
  gatewayTransactionId String?       @map("gateway_transaction_id") @db.VarChar(255)
  amount               Decimal       @db.Decimal(12, 2)
  currency             Currency      @default(BRL)
  paymentMethod        PaymentMethod @map("payment_method")

  // Status
  status        PaymentStatus @map("status")
  failureReason String?       @map("failure_reason") @db.VarChar(255)
  errorCode     String?       @map("error_code") @db.VarChar(100)
  errorMessage  String?       @map("error_message") @db.Text

  // Card info (if applicable)
  cardLastFour String? @map("card_last_four") @db.VarChar(4)
  cardBrand    String? @map("card_brand") @db.VarChar(50)

  // Refund info
  refundable   Boolean @default(false) 
  refundAmount String? @map("refund_amount") @db.VarChar(20)
  refundReason String? @map("refund_reason") @db.VarChar(255)

  // Provider data
  providerData Json? @map("provider_data") @db.JsonB

  // Timestamps
  createdAt   DateTime  @default(now()) @map("createdat") @db.Timestamp(0)
  processedAt DateTime? @map("processed_at") @db.Timestamp(3)
  refundedAt  DateTime? @map("refunded_at") @db.Timestamp(3)
  updatedAt   DateTime  @updatedAt @map("updatedat") @db.Timestamp(0)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

/// Vouchers and promotional codes
model Voucher {
  id          String  @id @default(uuid()) 
  userId      String?  // null = public voucher
  code        String  @unique @db.VarChar(50)
  description String? @db.Text

  // Discount
  discountType String   @db.VarChar(20) // "percentage" or "fixed"
  discount     Decimal  @db.Decimal(10, 2)
  maxDiscount  Decimal? @db.Decimal(10, 2) // max discount for percentage

  // Validity
  validFrom   DateTime @db.Date
  validUntil  DateTime @db.Date
  maxUses     Int?     @db.SmallInt
  currentUses Int      @default(0) @db.SmallInt
  usesPerUser Int?     @default(1) @db.SmallInt

  // Restrictions 
  minPurchaseAmount      Decimal? @db.Decimal(10, 2)
  applicableDestinations Json
  applicableCategories   Json

  // Status
  active Boolean @default(true)

  createdAt DateTime @default(now()) @map("createdat") @db.Timestamp(0)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Opposite relation for VoucherUsage.voucher
  usages VoucherUsage[]

  @@index([userId])
  @@map("vouchers")
}

/// Marketing promotions
model Promotion {
  id          String    @id @default(uuid()) 
  title       String    @db.VarChar(255)
  description String?   @db.Text
  code        String    @unique @db.VarChar(50)
  type        String    @db.VarChar(50) // 'percentage' | 'fixed' | 'free_shipping'
  value       Float     @db.Real // Discount value (percentage or fixed amount)
  active      Boolean   @default(true)
  startDate   DateTime  @default(now()) @db.Timestamp(0)
  expiresAt   DateTime  @db.Timestamp(3)
  maxUses     Int?      
  usedCount   Int       @default(0) 
  minPurchase Float?    @db.Real
  packageIds  Json  @default("[]") // Array of package IDs this applies to
  createdAt   DateTime  @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updatedat") @db.Timestamp(0)
  deletedAt   DateTime? @db.Timestamp(3)

  @@index([active, expiresAt])
  @@index([code])
  @@map("promotions")
}

model SystemPaymentMethod {
  id                   String   @id @default(uuid()) 
  name                 String   @db.VarChar(255)
  nameLocalized        Json?    @db.JsonB
  description          String?  @db.Text
  descriptionLocalized Json?    @db.JsonB
  type                 String   @db.VarChar(50)
  provider             String   @db.VarChar(100)
  iconName             String?  @db.VarChar(100)
  logoUrl              String?  @db.VarChar(500)
  status               String   @default("ativo") @db.VarChar(20)
  fees                 Json?    @db.JsonB
  countriesAvailable   Json
  currenciesAccepted   Json
  isOnline             Boolean  @default(true)
  isInstant            Boolean  @default(true)
  requiresSetup        Boolean  @default(false)
  setupUrl             String?  @db.VarChar(500)
  documentationUrl     String?  @db.VarChar(500)
  config               Json?    @db.JsonB
  limits               Json?    @db.JsonB
  processingTime       Json?    @db.JsonB
  metadata             Json?    @db.JsonB
  priority             Int      @default(0)
  isDefault            Boolean  @default(false)
  isTestMode           Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("createdat") @db.Timestamp(0)
  updatedAt            DateTime @updatedAt @map("updatedat") @db.Timestamp(0)

  @@map("system_payment_methods")
}

/// Voucher usage tracking
model VoucherUsage {
  id        String   @id @default(uuid()) 
  voucherId String   
  userId    String   
  usedAt    DateTime @default(now()) @map("usedat") @db.Timestamp(0)

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
  @@map("voucher_usage")
}

// ============================================
// ENUMS
// ============================================

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
  PARTIALLY_REFUNDED
  SUCCEEDED
  CANCELED
  REQUIRES_ACTION
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  PIX
  PAYPAL
  STRIPE
  CASH
  CRYPTO
  GIFT_CARD
}

// ============================================
//  SOCIAL, CONTENT, AI & SYSTEM
// ============================================

// ============================================
// TRIPS & ITINERARIES
// ============================================

/// Trip planning
model Trip {
  id            String  @id @default(uuid()) 
  userId        String  @map("user_id") 
  name          String  @db.VarChar(255)
  slug          String? @db.VarChar(255)
  description   String? @db.Text
  coverImageUrl String? @map("cover_image_url") @db.VarChar(500)

  // Dates
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  durationDays Int?     @map("duration_days")  // Generated in SQL

  // Status & Visibility
  status             TripStatus @default(DRAFT) @map("status")
  isPrivate          Boolean    @default(true) @map("is_private")
  isDraft            Boolean    @default(true) @map("is_draft")
  progressPercentage Int        @default(0) @map("progress_percentage") @db.SmallInt

  // Budget
  totalBudget    Decimal? @map("total_budget") @db.Decimal(12, 2)
  totalSpent     Decimal? @default(0) @map("total_spent") @db.Decimal(12, 2)
  budgetCurrency Currency @default(BRL) @map("budget_currency")

  // Budget breakdown
  accommodationBudget  Decimal? @map("accommodation_budget") @db.Decimal(10, 2)
  accommodationSpent   Decimal? @default(0) @map("accommodation_spent") @db.Decimal(10, 2)
  transportationBudget Decimal? @map("transportation_budget") @db.Decimal(10, 2)
  transportationSpent  Decimal? @default(0) @map("transportation_spent") @db.Decimal(10, 2)
  foodBudget           Decimal? @map("food_budget") @db.Decimal(10, 2)
  foodSpent            Decimal? @default(0) @map("food_spent") @db.Decimal(10, 2)
  activitiesBudget     Decimal? @map("activities_budget") @db.Decimal(10, 2)
  activitiesSpent      Decimal? @default(0) @map("activities_spent") @db.Decimal(10, 2)
  entertainmentBudget  Decimal? @map("entertainment_budget") @db.Decimal(10, 2)
  entertainmentSpent   Decimal? @default(0) @map("entertainment_spent") @db.Decimal(10, 2)
  otherBudget          Decimal? @map("other_budget") @db.Decimal(10, 2)
  otherSpent           Decimal? @default(0) @map("other_spent") @db.Decimal(10, 2)

  // Trip details
  originLocation  String?  @map("origin_location") @db.VarChar(255)
  originLatitude  Decimal? @map("origin_latitude") @db.Decimal(10, 8)
  originLongitude Decimal? @map("origin_longitude") @db.Decimal(11, 8)
  tripType        String?  @map("trip_type") @db.VarChar(50) // "solo", "couple", "family", "group"
  travelMode      String?  @map("travel_mode") @db.VarChar(50) // "car", "flight"

  // Companions
  companionsCount Int   @default(0) @map("companions_count")
  companions      Json? @db.JsonB // Array of user IDs and names

  // Statistics
  destinationsCount Int @default(0) @map("destinations_count")
  bookingsCount     Int @default(0) @map("bookings_count")
  photosCount       Int @default(0) @map("photos_count")

  // AI insights
  aiItinerarySuggestions Json?    @map("ai_itinerary_suggestions") @db.JsonB
  estimatedTotalCost     Decimal? @map("estimated_total_cost") @db.Decimal(12, 2)

  // Timestamps
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  startedAt  DateTime? @map("started_at") @db.Timestamp(3)
  endedAt    DateTime? @map("ended_at") @db.Timestamp(3)
  archivedAt DateTime? @map("archived_at") @db.Timestamp(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(3)

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  itinerary    Itinerary?
  destinations TripDestination[]

  @@index([userId])
  @@index([status])
  @@map("trips")
}

/// AI-generated itinerary

model Itinerary {
  id     String @id @default(uuid()) 
  tripId String @unique 

  overview        String? @db.Text
  recommendations Json?   @db.JsonB
  optimizedRoute  Json?   @db.JsonB
  metadata        Json?   @db.JsonB

  createdAt  DateTime       @default(now()) @db.Timestamp(0)
  updatedAt  DateTime       @updatedAt @db.Timestamp(0)
  trip       Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities ItineraryDay[]

  @@map("itineraries")
}

/// Daily itinerary
model ItineraryDay {
  id          String   @id @default(uuid()) 
  itineraryId String   
  dayNumber   Int      @db.SmallInt
  date        DateTime @db.Date
  title       String?  @db.VarChar(255)
  description String?  @db.Text
  activities  Json     @db.JsonB
  weather     Json?    @db.JsonB
  budget      Decimal? @db.Decimal(10, 2)

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
  @@map("itinerary_days")
}

/// Link between trips and destinations
model TripDestination {
  id            String @id @default(uuid()) 
  tripId        String @map("trip_id") 
  destinationId String @map("destination_id") 

  sequenceOrder Int       @map("sequence_order") 
  arrivalDate   DateTime? @map("arrival_date") @db.Date
  departureDate DateTime? @map("departure_date") @db.Date
  durationDays  Int?      @map("duration_days") 

  budget Decimal? @db.Decimal(10, 2)
  spent  Decimal? @default(0) @db.Decimal(10, 2)

  notes            String? @db.Text
  itineraryDetails Json?   @map("itinerary_details") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  trip        Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id])
  bookings    Booking[]   @relation("TripDestinationBookings")

  @@unique([tripId, destinationId, sequenceOrder])
  @@map("trip_destinations")
}

/// Saved itineraries

model SavedItinerary {
  id            String   @id @default(uuid()) 
  userId        String   
  destinationId String?  
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  slug          String?  @unique @db.VarChar(255)
  itineraryData Json     @db.JsonB
  duration      Int      @db.SmallInt
  budget        Decimal? @db.Decimal(10, 2)
  currency      Currency @default(BRL)
  preferences   Json?    @db.JsonB
  aiModel       String?  @db.VarChar(50)
  version       Int      @default(1) @db.SmallInt

  // Sharing
  isPublic  Boolean @default(false)
  shareCode String? @unique @db.VarChar(50)
  views     Int     @default(0)
  likes     Int     @default(0)

  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id])

  @@index([userId])
  @@map("saved_itineraries")
}

// ============================================
// REVIEWS & RATINGS
// ============================================

/// Reviews for bookings/destinations/services
model Review {
  id            String  @id @default(uuid()) 
  userId        String  @map("user_id") 
  bookingId     String? @map("booking_id") 
  destinationId String? @map("destination_id") 
  attractionId  String? @map("attraction_id") 

  // Review content
  title   String @db.VarChar(255)
  comment String @db.Text
  rating  Int    @db.SmallInt // 1-5

  // Breakdown ratings
  cleanlinessRating Int? @map("cleanliness_rating") @db.SmallInt
  comfortRating     Int? @map("comfort_rating") @db.SmallInt
  locationRating    Int? @map("location_rating") @db.SmallInt
  valueRating       Int? @map("value_rating") @db.SmallInt
  serviceRating     Int? @map("service_rating") @db.SmallInt

  // Metadata
  reviewerName      String?      @map("reviewer_name") @db.VarChar(255)
  reviewType        ReviewType   @default(POST_TRIP) @map("review_type")
  reviewStatus      ReviewStatus @default(PENDING) @map("review_status")
  isVerifiedBooking Boolean      @default(false) @map("is_verified_booking")
  travelType        String?      @map("travel_type") @db.VarChar(50) // "solo", "couple", "family", "business"

  // Engagement
  helpfulCount   Int @default(0) @map("helpful_count")
  unhelpfulCount Int @default(0) @map("unhelpful_count")
  flagCount      Int @default(0) @map("flag_count")

  // Media
  photos Json? @db.JsonB // Array of image URLs with captions
  videos Json? @db.JsonB // Array of video URLs

  // Moderation
  moderationNotes String? @map("moderation_notes") @db.Text
  isFeatured      Boolean @default(false) @map("is_featured")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  publishedAt DateTime? @map("published_at") @db.Timestamp(3)
  moderatedAt DateTime? @map("moderated_at") @db.Timestamp(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking     Booking?     @relation("ReviewBooking", fields: [bookingId], references: [id])
  destination Destination? @relation("DestinationReviews", fields: [destinationId], references: [id])
  attraction  Attraction?  @relation(fields: [attractionId], references: [id])

  @@index([bookingId])
  @@index([userId])
  @@index([destinationId])
  @@map("reviews")
}

// FAVORITES & WISHLISTS
// ============================================

/// Favorite items (generic)
model Favorite {
  id       String @id @default(uuid()) 
  userId   String 
  itemType String @db.VarChar(50) // "destination", "service", "article"
  itemId   String 

  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@map("favorites")
}

/// Destination-specific favorites
model UserFavorite {
  id            String  @id @default(uuid()) 
  userId        String  
  destinationId String  
  priority      Int     @default(0) @db.SmallInt // sorting order
  notes         String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  user        User        @relation("UserDestinationFavorites", fields: [userId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
  @@map("user_favorites")
}

// ============================================
// AI FEATURES
// ============================================

/// AI conversation threads
model AiConversation {
  id                 String    @id @default(uuid()) 
  userId             String?   
  title              String?   @db.VarChar(255)
  conversationStatus String    @default("active") @db.VarChar(20) // 'active' | 'resolved' | 'escalated' | 'closed'
  escalatedToEmail   Boolean   @default(false)
  escalatedAt        DateTime? @db.Timestamp(3)
  context            Json?     @db.JsonB
  createdAt          DateTime  @default(now()) @db.Timestamp(0)
  updatedAt          DateTime  @updatedAt @db.Timestamp(0)

  messages   ChatMessage[]
  aiMessages AiMessage[]
  user       User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationStatus])
  @@index([updatedAt])
  @@map("ai_conversations")
}

/// Chat messages within AI conversations
model ChatMessage {
  id               String   @id @default(uuid()) 
  aiConversationId String   
  userId           String?  
  role             String   @db.VarChar(20) // 'user' | 'assistant' | 'system'
  content          String   @db.Text
  metadata         Json?    @db.JsonB
  createdAt        DateTime @default(now()) @db.Timestamp(0)
  updatedAt        DateTime @updatedAt @db.Timestamp(0)

  conversation AiConversation @relation(fields: [aiConversationId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([aiConversationId])
  @@index([userId])
  @@index([createdAt])
  @@map("ai_chat_messages")
}

// AI messages (legacy - keeping for backward compatibility)
model AiMessage {
  id             String @id @default(uuid()) 
  conversationId String 
  role           String @db.VarChar(20) // "user", "assistant", "system"
  content        String @db.Text

  tokens           Int?     
  model            String?  @db.VarChar(50)
  metadata         Json?    @db.JsonB
  promptTokens     Int?     
  completionTokens Int?     
  helpful          Boolean?
  rating           Int?     @db.SmallInt

  createdAt        DateTime       @default(now()) @db.Timestamp(0)
  updatedAt        DateTime       @updatedAt @db.Timestamp(0)
  aiConversationId String         
  aiConversation   AiConversation @relation(fields: [aiConversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, id])
  @@index([aiConversationId])
  @@map("ai_messages")
}

// ============================================
// CHAT & MESSAGING
// ============================================

/// Chat rooms (1-on-1 or group)
model ChatRoom {
  id   String  @id @default(uuid()) 
  type String  @db.VarChar(20) // "direct" or "group"
  name String? @db.VarChar(255) // for groups

  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  participants ChatParticipant[]
  messages     RoomMessage[]

  @@map("chat_rooms")
}

/// Chat participants
model ChatParticipant {
  id       String    @id @default(uuid()) 
  roomId   String    
  userId   String    
  role     String    @db.VarChar(20) // "member" or "admin"
  joinedAt DateTime  @default(now()) @db.Timestamp(0)
  leftAt   DateTime? @db.Timestamp(3)

  room     ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Opposite relation for ChatMessage.chatParticipant
  messages RoomMessage[]

  @@unique([roomId, userId])
  @@map("chat_participants")
}

/// Room messages (for chat rooms)
model RoomMessage {
  id      String @id @default(uuid()) 
  roomId  String 
  userId  String 
  content String @db.Text
  type    String @db.VarChar(20) // "text", "image", "file"

  // Reactions
  reactions Json? @db.JsonB // { "👍": ["userId1", "userId2"] }

  //   Status 
  edited    Boolean   @default(false)
  editedAt  DateTime? @db.Timestamp(3)
  deleted   Boolean   @default(false)
  deletedAt DateTime? @db.Timestamp(3)

  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)

  room            ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatParticipant ChatParticipant @relation(fields: [roomId, userId], references: [roomId, userId], onDelete: Cascade)

  @@index([roomId, createdAt])
