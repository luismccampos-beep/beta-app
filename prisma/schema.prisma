model Article {
  id            String  @id @default(uuid()) 
  authorId      String  @map("author_id") 
  author        User    @relation("UserArticles", fields: [authorId], references: [id])
  destinationId String? @map("destination_id") 
  title         String  @db.VarChar(500)
  slug          String  @unique @db.VarChar(500)
  content       String  @db.Text
  excerpt       String? @db.VarChar(1000)

  // Media
  coverImage       String? @map("featured_image_url") @db.VarChar(500)
  featuredImageAlt String? @map("featured_image_alt") @db.Text
  images           Json?   @db.JsonB
  videoUrl         String? @map("video_url") @db.VarChar(500)

  // Metadata
  contentType        ContentType      @default(article) @map("content_type")
  category           ArticleCategory? @default(travel_guide)
  tags               Json?            @db.JsonB
  readingTimeMinutes Int?             @map("reading_time_minutes") 
  word_count         Int?             

  // Status & Publishing
  status      ArticleStatus @default(draft)
  publishedAt DateTime?     @map("published_at") @db.Timestamp(3)
  scheduledAt DateTime?     @map("scheduled_at") @db.Timestamp(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamp(0)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(0)

  // Featured & Visibility
  isFeatured Boolean   @default(false) @map("is_featured")
  isPinned   Boolean   @default(false) @map("is_pinned")
  pinUntil   DateTime? @map("pin_until") @db.Timestamp(3)
  visibility String    @default("public") @db.VarChar(50)

  // Sustainability Features
  sustainabilityRating    Int?                    @default(0) @map("sustainability_rating") @db.SmallInt
  sustainabilityCategory  SustainabilityCategory? @map("sustainability_category")
  carbonFootprintEstimate Int?                    @map("carbon_footprint_estimate") 
  ecoCertifications       Json?                   @map("eco_certifications") @db.JsonB

  // Security Features
  securityLevel          SecurityLevel @default(medium) @map("security_level")
  requiresAuthentication Boolean       @default(false) @map("requires_authentication")
  contentWarning         String?       @map("content_warning") @db.Text

  // Analytics & Engagement
  viewsCount       Int @default(0) @map("views_count")
  uniqueViewsCount Int @default(0) @map("unique_views_count")
  likesCount       Int @default(0) @map("likes_count")
  sharesCount      Int @default(0) @map("shares_count")
  commentsCount    Int @default(0) @map("comments_count")
  bookmarkCount    Int @default(0) @map("bookmark_count")

  // AI & Trending
  trendScore   Int     @default(0) @map("trend_score") @db.SmallInt
  trendingRank Int?    @map("trending_rank")
  aiGenerated  Boolean @default(false) @map("ai_generated")
  aiSummary    String? @map("ai_summary") @db.Text
  aiKeywords   Json?   @map("ai_keywords") @db.JsonB

  // SEO
  metaTitle       String? @map("meta_title") @db.VarChar(160)
  metaDescription String? @map("meta_description") @db.VarChar(160)
  metaKeywords    String? @map("meta_keywords") @db.VarChar(500)
  canonicalUrl    String? @map("canonical_url") @db.VarChar(500)
  structuredData  Json?   @map("structured_data") @db.JsonB

  // Internal Linking
  relatedArticles Json? @map("related_articles") @db.JsonB

  // Moderation
  isApproved      Boolean   @default(true) @map("is_approved")
  moderationNotes String?   @map("moderation_notes") @db.Text
  moderatedBy     String?   @map("moderated_by") 
  moderatedAt     DateTime? @map("moderated_at") @db.Timestamp(3)

  moderator User? @relation("ModeratedArticles", fields: [moderatedBy], references: [id])

  destination  Destination?         @relation(fields: [destinationId], references: [id])
  destinations ArticleDestination[]
  attractions  ArticleAttraction[]
  comments     ArticleComment[]

  @@index([slug])
  @@index([isFeatured])
  @@index([authorId])
  @@index([destinationId])
  @@index([moderatedBy])
  @@map("articles")
}

model ArticleComment {
  id              String  @id @default(uuid()) 
  articleId       String  @map("article_id") 
  userId          String? @map("user_id") 
  parentCommentId String? @map("parent_comment_id") 

  // Guest commenting
  guestName     String? @map("guest_name") @db.VarChar(255)
  guestEmail    String? @map("guest_email") @db.VarChar(255)
  guestVerified Boolean @default(false) @map("guest_verified")

  // Content
  title       String? @db.VarChar(500)
  content     String  @db.Text
  ratingGiven Int?    @map("rating_given") @db.SmallInt

  // Status
  status             CommentStatus @default(pending)
  isVerifiedPurchase Boolean       @default(false) @map("is_verified_purchase")
  isPinned           Boolean       @default(false) @map("is_pinned")

  // Content warnings
  contentWarning String? @map("content_warning") @db.Text

  // Analytics
  likesCount     Int @default(0) @map("likes_count")
  dislikesCount  Int @default(0) @map("dislikes_count")
  helpfulCount   Int @default(0) @map("helpful_count")
  unhelpfulCount Int @default(0) @map("unhelpful_count")

  // Moderation
  moderationNotes String?   @map("moderation_notes") @db.Text
  moderatedBy     String?   @map("moderated_by") 
  moderatedAt     DateTime? @map("moderated_at") @db.Timestamp(3)

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(3)

  // Depth tracking
  depth Int @default(0) 

  article       Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user          User?            @relation("UserComments", fields: [userId], references: [id], onDelete: SetNull)
  parentComment ArticleComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  replies       ArticleComment[] @relation("CommentReplies")
  moderator     User?            @relation("ModeratedComments", fields: [moderatedBy], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@index([userId])
  @@index([parentCommentId])
  @@index([moderatedBy])
  @@map("article_comments")
}

