// ============================================
// NOTE: Table naming is inconsistent — some models use @map("created_at") and others
// @map("createdat"). New models should use snake_case with underscores for consistency.
// A future migration should standardize all tables to one convention.
// ============================================

// ============================================
// AUTH & USER MANAGEMENT (Ajustado para PTisp)
// ============================================

datasource db {
  provider     = "postgresql"
  // Neon / Vercel: usa apenas DATABASE_URL (pooled).
  // Migrations são executadas via GitHub Actions, não no build do Vercel.
  // Postgres natively supports FK constraints, so Prisma's relation emulation layer is unnecessary
  // and was harming query plans (nested mutations run an extra round-trip) and dropping database-level
  // referential integrity. With foreignKeys, the schema's @relation declarations are enforced by the DB
  // and Prisma simply trusts them.
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

