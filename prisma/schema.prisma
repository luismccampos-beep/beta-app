/// CRM Event Analytics for tracking customer interactions
model CrmEvent {
  id         String   @id @default(uuid()) 
  type       String   @db.VarChar(50)
  customerId String?  
  payload    Json?    @db.JsonB
  timestamp  DateTime @db.Timestamp(3)
  receivedAt DateTime @default(now()) @db.Timestamp(0)
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  sessionId  String?  @db.VarChar(255)

  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@index([customerId])
  @@index([type])
  @@index([timestamp])
  @@map("crm_events")
}

/// CRM Customer management
model CrmCustomer {
  id        String   @id @default(uuid()) 
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  cpfCnpj   String   @db.VarChar(20) // CPF or CNPJ
  birthDate DateTime @db.Timestamp(3)

  // Address
  street       String  @db.VarChar(255)
  number       String  @db.VarChar(10)
  complement   String? @db.VarChar(50)
  neighborhood String? @db.VarChar(50)
  city         String  @db.VarChar(100)
  state        String  @db.VarChar(2)
  zipCode      String  @db.VarChar(10)
  country      String  @db.VarChar(3)

  // Additional info
  documents        Json?   @db.JsonB // Array of document objects
  notes            String? @db.Text
  marketingConsent Boolean @default(false)

  // Status
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(3)

  // Relationships
  bookings CrmBooking[]

  @@index([email])
  @@index([cpfCnpj])
  @@index([city, state])
  @@map("crm_customers")
}

/// CRM Booking management
model CrmBooking {
  id            String @id @default(uuid()) 
  reference     String @unique @db.VarChar(20) // BK-XXXXX-XXXXX format
  customerId    String 
  destinationId String 

  // Booking details
  type          String   @db.VarChar(20) // 'flight', 'hotel', 'package', 'car'
  startDate     DateTime @db.Timestamp(3)
  endDate       DateTime @db.Timestamp(3)
  totalPrice    Decimal  @db.Decimal(10, 2)
  status        String   @default("pending") @db.VarChar(20) // 'confirmed', 'pending', 'cancelled'
  paymentMethod String?  @db.VarChar(20)
  paymentProof  String?  @db.Text

  // Additional info
  notes String? @db.Text

  // Status
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(3)

  // Relationships
  customer CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([reference])
  @@index([status])
  @@index([startDate, endDate])
  @@map("crm_bookings")
}

/// CRM Product Category
model CrmCategory {
  id          String  @id @default(uuid()) 
  name        String  @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  description String? @db.Text

  // Status
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @db.Timestamp(0)
  deletedAt DateTime? @db.Timestamp(3)

  // Relationships
  products CrmProduct[]

  @@index([slug])
  @@map("crm_categories")
}

/// CRM Product catalog
model CrmProduct {
  id          String   @id @default(uuid()) 
  sku         String   @unique @db.VarChar(50)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  costPrice   Decimal? @db.Decimal(10, 2)
  currency    Currency @default(BRL)

  // Category
  categoryId String? 

