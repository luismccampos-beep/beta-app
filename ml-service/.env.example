# Environment Configuration
NODE_ENV=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=3002
DEBUG=true

# Database (optional - for enhanced features)
DATABASE_URL=mysql://akmelvap_user_beta:A_TUA_PASSWORD@localhost:3306/akmelvap_db_beta

# Redis Cache (optional - for caching ML results)
REDIS_URL=redis://localhost:6379

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=info

# ML Configuration
MODEL_CACHE_TTL=3600
RECOMMENDATION_BATCH_SIZE=100
PERSONALIZATION_UPDATE_INTERVAL=1800

# Security
API_KEY=dev_ml_service_api_key_minimum_32_characters_long
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
