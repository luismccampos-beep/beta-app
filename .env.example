# Prisma (PostgreSQL — Neon on Vercel, or local Docker)
# Neon sets DATABASE_URL (pooled) + DATABASE_URL_UNPOOLED (direct). Prisma needs both.
# If `vercel env pull` leaves only VERCEL_OIDC_TOKEN, open Vercel → Project → Settings →
# Environment Variables and enable the Neon vars for "Development" too, then pull again.
# Local Docker: use the same URL for both (no PgBouncer).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Default origin IATA for flight search + preferences → results (e.g. LIS)
NEXT_PUBLIC_DEFAULT_ORIGIN_IATA="LIS"

# Internal calls from middleware -> API routes (optional in dev)
INTERNAL_API_KEY=""

# ML Service (FastAPI) - embeddings + SCGraph road distance (/v1/travel/rank, /v1/travel/distance)
ML_SERVICE_BASE_URL="http://localhost:3002"
ML_SERVICE_API_KEY=""
# ml-service: pip install scgraph  |  ML_SERVICE_SCGRAPH_GEOGRAPH=world_highways
# Train embeddings: npm run travel:ml:build  (export Wikivoyage CSV + train in ml-service)

# Catálogo Wikivoyage: bundle JSON (default) ou Postgres (API interna v1)
# TRAVEL_CATALOG_SOURCE=db
# npm run travel:catalog:migrate && npm run travel:catalog:import
# GET /api/travel/v1/destinations | /hotels | /flights | /cost-of-living | /listings
# OSM hotels (free): /hotels/osm | /hotels/geocode | docs/OSM_HOTELS.md
# BIZDATA_API_BASE_URL="https://bizdata-web.vercel.app"
# PHOTON_API_BASE_URL="https://photon.komoot.io"
# PHOTON_USER_AGENT="beta-app-travel/1.0 (you@example.com)"

# Demo travel data (hotels + flights) when Hotelbeds/Duffel are missing
# TRAVEL_USE_MOCK_DATA=true
# TRAVEL_DEMO_DATA=wikivoyage   # use bundle from Wikivoyage (default if bundle-wikivoyage.json exists)
# TRAVEL_DEMO_DATA=faker        # use small faker bundle only
# Build large demo DB: npm run travel:demo:full
# Regenerate small faker JSON: npm run mock:travel:generate
# MOCK_DESTINOS=200 MOCK_HOTEIS=2000 MOCK_VOOS=3000

# Duffel (flights reference data: airports, loyalty programmes; cabin enums align with offers)
DUFFEL_ACCESS_TOKEN=""

# Hotelbeds Content API (accommodation types, chains, facilities) — test: https://api.test.hotelbeds.com
HOTELBEDS_API_KEY=""
HOTELBEDS_API_SECRET=""
# Optional override (default: https://api.test.hotelbeds.com)
# HOTELBEDS_API_BASE_URL="https://api.hotelbeds.com"

# LiteAPI — hotel places autocomplete + rates/booking (server-side only)
# Dashboard: https://dashboard.liteapi.travel/  |  Docs: https://docs.liteapi.travel/
LITEAPI_API_KEY=""
# LITEAPI_API_BASE_URL="https://api.liteapi.travel/v3.0"
# GET /api/travel/liteapi/places?q=Lisboa&type=locality,hotel&language=pt

# Crawlbase — Google Hotels scrapers (offline scripts, JS token required)
# https://crawlbase.com/dashboard
CRAWLBASE_JS_TOKEN=""
# npm run travel:google-hotels:install
# npm run travel:google-hotels:listings -- --location Lisboa
# npm run travel:google-hotels:details -- --limit 5

# Pixabay — alto volume; imagens em public/travel-images/ (https://pixabay.com/api/docs/)
# PIXABAY_API_KEY=""
# Pexels — fotos dos destinos (~200 req/h) https://www.pexels.com/api/
# PEXELS_API_KEY=""
# Unsplash — fallback (~50 req/h demo) https://unsplash.com/oauth/applications
# UNSPLASH_ACCESS_KEY=""
# UNSPLASH_SECRET_KEY=""
# Enriquecer: npm run travel:images:enrich  |  Progresso: npm run travel:images:status
# Corrigir fotos repetidas: npm run travel:images:dedupe  (força URL única; melhor que refresh-duplicates)
# TRAVEL_IMAGES_REFRESH=all  — re-enriquece todos os que já têm foto
# Ordem: Pexels → Pixabay (cache local) → Unsplash
# UNSPLASH_ENRICH_LIMIT=250   UNSPLASH_MAX_API_CALLS=300   UNSPLASH_ONLY_IATA=1
# On-demand (só Unsplash no route atual): GET /api/travel/unsplash-image?nome=Lisboa&pais=Portugal

# Enriquecimento offline do bundle (Wikipedia + clima → JSON)
# OPENWEATHER_API_KEY=""   # https://openweathermap.org/api (free tier)
# EXTERNAL_ENRICH_LIMIT=200
# npm run travel:demo:enrich-external

# Voos: Duffel (ofertas bookable) ou fallback Google Flights via Scrape.do.
# Prioridade na pesquisa: Duffel → Scrape.do → mock (TRAVEL_USE_MOCK_DATA).

# Scrape.do — Google Flights plugin (async API)
# Token: https://scrape.do/dashboard
SCRAPE_DO_API_KEY=""
# Alias aceite: SCRAPE_DO_TOKEN
# SCRAPE_DO_FLIGHTS_CURRENCY="EUR"

# Roteamento local (demo sem API na cloud)
# Valhalla — carro / a pé / bike (docker compose up valhalla -d)
VALHALLA_BASE_URL="http://localhost:8002"
# OpenTripPlanner — transit GTFS (npm run otp:prepare && npm run otp:build && npm run otp:up)
OTP_BASE_URL="http://localhost:8080"
# Só motores locais, nunca TripGo na cloud:
TRAVEL_ROUTING_LOCAL_ONLY=true
# GET /api/travel/routing/local?from=lat,lon&to=lat,lon&mode=transit|auto|pedestrian|bicycle

# TripGo — fallback multimodal na cloud (opcional se Valhalla estiver ativo)
# Chave gratuita: https://tripgo.3scale.net/signup
TRIPGO_API_KEY=""
# GET /api/travel/tripgo/routing?from=lat,lon&to=lat,lon&modes=pt_pub_wa_wal

# Siloah Travel — luxury cruises (no API key; optional base URL override)
# SILOAH_API_BASE_URL="https://mcp.siloah.travel"

# Results API (/api/travel/results) query params (optional):
# Cruises: GET /api/travel/cruises?destination=Mediterranean&maxPrice=3000&mode=cruises
# tripType=oneway|roundtrip   mode=both|flights|hotels   nights=1-30
# return=YYYY-MM-DD (round-trip return; default: departure + nights)

