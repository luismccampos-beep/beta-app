# Prisma (PostgreSQL — Neon on Vercel, or local Docker)
# Neon sets DATABASE_URL (pooled) + DATABASE_URL_UNPOOLED (direct). Prisma needs both.
# If `vercel env pull` leaves only VERCEL_OIDC_TOKEN, open Vercel → Project → Settings →
# Environment Variables and enable the Neon vars for "Development" too, then pull again.
# Local Docker: use the same URL for both (no PgBouncer).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Default origin IATA for flight search + preferences → results (e.g. LIS)
NEXT_PUBLIC_DEFAULT_ORIGIN_IATA="LIS"

# Internal calls from middleware -> API routes (optional in dev)
INTERNAL_API_KEY=""

# ML Service (FastAPI) - AI insights (Gemini-backed)
ML_SERVICE_BASE_URL="http://localhost:3002"
ML_SERVICE_API_KEY=""

# Duffel (flights reference data: airports, loyalty programmes; cabin enums align with offers)
DUFFEL_ACCESS_TOKEN=""

# Hotelbeds Content API (accommodation types, chains, facilities) — test: https://api.test.hotelbeds.com
HOTELBEDS_API_KEY=""
HOTELBEDS_API_SECRET=""
# Optional override (default: https://api.test.hotelbeds.com)
# HOTELBEDS_API_BASE_URL="https://api.hotelbeds.com"

# Results API (/api/travel/results) query params (optional):
# tripType=oneway|roundtrip   mode=both|flights|hotels   nights=1-30
# return=YYYY-MM-DD (round-trip return; default: departure + nights)

