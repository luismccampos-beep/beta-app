{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": [
          "dist/**",
          ".next/**",
          "!.next/cache/**",
          "build/**",
          "out/**"
        ],
        "env": [
          "NODE_ENV",
          "NEXT_PUBLIC_*",
          "DATABASE_URL",
          "NEXTAUTH_URL",
          "AUTH_SECRET",
          "AUTH_URL"
        ]
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "lint": {
        "dependsOn": ["^build"],
        "outputs": [],
        "cache": true
      },
      "type-check": {
        "dependsOn": ["^build"],
        "outputs": ["*.tsbuildinfo"],
        "cache": true
      },
      "test": {
        "dependsOn": ["^build"],
        "outputs": ["coverage/**"],
        "cache": true,
        "env": ["NODE_ENV"]
      },
      "test:watch": {
        "cache": false,
        "persistent": true
      },
      "test:ci": {
        "dependsOn": ["^build"],
        "outputs": ["coverage/**"],
        "cache": true
      },
      "clean": {
        "cache": false
      },
      "format": {
        "outputs": [],
        "cache": true
      },
      "format:check": {
        "outputs": [],
        "cache": true
      }
    },
    "globalDependencies": ["package.json", "tsconfig.json", ".env", ".env.local"],
    "globalEnv": ["NODE_ENV", "CI", "VERCEL", "VERCEL_ENV"],
    "globalPassThroughEnv": ["NODE_ENV", "TERM", "SHELL", "PATH"]
  }
  