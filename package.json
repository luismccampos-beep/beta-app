{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@akmleva/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && cross-env NODE_ENV=production DISABLE_SSR_FETCH=true next build",
    "vercel-build": "prisma generate && cross-env NODE_ENV=production DISABLE_SSR_FETCH=true next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "i18n:extract": "npx tsx scripts/extract-next-intl.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "test:changed": "vitest run --changed",
    "test:changed:watch": "vitest watch --changed",
    "test:changed:coverage": "vitest run --changed --coverage",
    "test:branch": "vitest run --changed HEAD~1",
    "test:staged": "vitest run --changed --staged"
  },
  "dependencies": {
    "@akmleva/auth": "file:./packages/auth",
    "@akmleva/shared": "file:./packages/shared",
