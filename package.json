{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "akmleva",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-with-fallback.mjs generate && cross-env NODE_ENV=production DISABLE_SSR_FETCH=true next build",
    "vercel-build": "node scripts/prisma-with-fallback.mjs generate && cross-env NODE_ENV=production DISABLE_SSR_FETCH=true next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "i18n:extract": "npx tsx scripts/extract-next-intl.ts",
    "postinstall": "node scripts/prisma-with-fallback.mjs generate",
    "prisma:generate": "node scripts/prisma-with-fallback.mjs generate",
    "prisma:migrate": "node scripts/prisma-with-fallback.mjs migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "node scripts/prisma-with-fallback.mjs db push",
    "db:migrate": "node scripts/prisma-with-fallback.mjs migrate deploy",
    "db:resolve": "node scripts/resolve-failed-migrations.mjs",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "node scripts/prisma-with-fallback.mjs migrate reset --force",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'scripts/__tests__/*.integration.test.*'",
    "test:integration": "vitest run scripts/__tests__/resolve-failed-migrations.integration.test.mjs",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:changed": "vitest run --changed",
    "test:changed:watch": "vitest watch --changed",
    "test:changed:coverage": "vitest run --changed --coverage",
    "storybook:build": "storybook build",
    "chromatic": "chromatic --build-script-name=storybook:build",
    "test:branch": "vitest run --changed HEAD~1",
    "test:staged": "vitest run --changed --staged",
    "data-pipeline": "npm run -w tools/data-pipeline"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
