{
  "name": "@akmleva/data-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "mock:travel:generate": "node scripts/generate-travel-mock-data.mjs",
    "wikivoyage:extract": "py -3 -X utf8 scripts/parse-wikivoyage-dump.py --lang both --listings",
    "wikivoyage:extract:pt": "py -3 -X utf8 scripts/parse-wikivoyage-dump.py --lang pt --listings",
    "wikivoyage:extract:en": "py -3 -X utf8 scripts/parse-wikivoyage-dump.py --lang en --listings",
    "travel:demo:build": "node scripts/build-travel-bundle-from-wikivoyage.mjs",
    "travel:demo:cards": "node scripts/enrich-bundle-destination-cards.mjs",
    "travel:demo:enrich-external": "node scripts/enrich-bundle-external.mjs",
    "travel:demo:enrich-geonames": "py -3 -X utf8 scripts/enrich-geonames.py",
    "travel:demo:enrich-budget": "node scripts/enrich-bundle-budget.mjs",
    "travel:demo:enrich-transport": "node scripts/enrich-bundle-transport.mjs",
    "travel:demo:build-hotel-index": "py -3 -X utf8 scripts/build-hotel-data-index.py",
    "travel:demo:enrich-hotels": "node scripts/enrich-bundle-hotels-from-data.mjs",
    "travel:demo:enrich-hotels-remaining": "node scripts/enrich-bundle-hotels-remaining.mjs",
    "travel:demo:enrich-hotels-from-db": "node scripts/enrich-bundle-hotels-from-db.mjs",
    "travel:demo:rebuild-flights": "node scripts/rebuild-bundle-flights-routes.mjs",
    "travel:demo:enrich-cultural-pois": "node scripts/enrich-bundle-cultural-pois.mjs",
    "travel:demo:enrich-cultural-pois:bizdata": "node scripts/enrich-bundle-cultural-pois.mjs --bizdata-only",
    "travel:demo:enrich-cultural-pois:resume": "node scripts/enrich-bundle-cultural-pois.mjs --resume",
    "travel:demo:enrich-hospitals-police": "node scripts/enrich-bundle-hospitals-police.mjs",
    "travel:demo:enrich-hospitals-police:resume": "node scripts/enrich-bundle-hospitals-police.mjs --resume",
    "travel:demo:enrich-rental-cars": "node scripts/enrich-bundle-rental-cars.mjs",
    "travel:demo:enrich-wikidata-pois": "node scripts/enrich-bundle-wikidata-pois.mjs",
    "travel:demo:enrich-overpass-country": "node scripts/enrich-bundle-overpass-country.mjs",
    "travel:demo:patch-countries": "node scripts/patch-bundle-countries.mjs",
    "travel:demo:full": "npm run wikivoyage:extract:pt && npm run travel:demo:build",
    "travel:demo:enrich-overture": "node scripts/enrich-bundle-overture-pois.mjs",
    "travel:demo:enrich-overture:dry": "node scripts/enrich-bundle-overture-pois.mjs --dry-run --limit=10",
    "travel:demo:enrich-overture:hospitals": "node scripts/enrich-bundle-overture-pois.mjs --hospitals-only",
    "travel:demo:enrich-overture:police": "node scripts/enrich-bundle-overture-pois.mjs --police-only",
    "travel:demo:enrich-overture:cultural": "node scripts/enrich-bundle-overture-pois.mjs --cultural-only",
    "travel:demo:enrich-overture:batch": "node scripts/enrich-bundle-overture-pois.mjs --batch=500 --radius=5000",
    "travel:demo:enrich-pipeline": "npm run travel:demo:patch-countries && npm run travel:demo:enrich-external && npm run travel:demo:enrich-transport && npm run travel:demo:enrich-budget && npm run travel:demo:rebuild-flights && npm run travel:demo:enrich-cultural-pois && npm run travel:demo:enrich-hospitals-police && npm run travel:demo:enrich-rental-cars",
    "travel:demo:enrich-pipeline:resume": "npm run travel:demo:enrich-cultural-pois && npm run travel:demo:enrich-hospitals-police && npm run travel:demo:enrich-rental-cars",
    "travel:demo:enrich-weather": "node scripts/enrich-bundle-weather.mjs",
    "travel:demo:validate-countries": "node scripts/validate-bundle-countries.mjs",
    "travel:demo:apply-wiki-to-bundle": "node scripts/apply-destinos-wiki-to-bundle.mjs",
    "travel:geonames:install": "py -3 -m pip install -r scripts/requirements-geonames.txt",
    "travel:geonames:verify": "py -3 -X utf8 scripts/verify-geonames.py",
    "travel:build:unesco-index": "node scripts/build-unesco-index.mjs",
    "travel:build:tourism-index": "node scripts/build-tourism-expenditure-index.mjs",
    "travel:import:pop-france": "node scripts/fetch-pop-france.mjs",
    "travel:fetch:wikidata-cultural": "node scripts/fetch-wikidata-cultural.mjs",
    "travel:import:protected-planet": "node scripts/fetch-protected-planet-country.mjs",
    "travel:import:cultural-all": "node scripts/import-cultural-all.mjs",
    "travel:fetch:overpass-destinations": "node scripts/fetch-overpass-destinations.mjs",
    "travel:catalog:migrate": "prisma migrate dev --name travel_wikivoyage_catalog",
    "travel:catalog:import-airports": "node scripts/import-airport-geo.mjs",
    "travel:catalog:sync-images": "node scripts/import-travel-catalog-to-db.mjs --images-only",
    "travel:catalog:backfill-geo": "node scripts/backfill-wv-hotels-geo.mjs",
    "travel:catalog:backfill-dest-geo": "node scripts/backfill-wv-destinations-geo.mjs",
    "travel:catalog:backfill-iata": "node scripts/backfill-wv-destinations-iata.mjs",
    "travel:catalog:geocode-hotels": "py -3 -X utf8 scripts/geocode-wv-hotels.py",
    "travel:catalog:geocode-hotels:parallel": "node scripts/geocode-wv-hotels-parallel.mjs",
    "travel:catalog:geocode-hotels:parallel:install": "echo 'No deps needed - uses built-in fetch API'",
    "travel:catalog:geocode-hotels:install": "py -3 -m pip install -r scripts/requirements-geocode-hotels.txt",

    "travel:catalog:geocode-hotels:copy-dest": "node scripts/copy-dest-coords-to-hotels.mjs",
    "travel:catalog:geocode-hotels:geocode-destinos": "node scripts/_geocode-destinos.mjs",
    "travel:catalog:geocode-hotels:combined": "node scripts/geocode-hotels-combined.mjs",
    "travel:catalog:geocode-hotels:combined:dry": "node scripts/geocode-hotels-combined.mjs --dry-run",
    "travel:catalog:geocode-hotels:combined:status": "node scripts/geocode-hotels-combined.mjs --status",
    "travel:catalog:tag-categorias": "node scripts/tag-destinos-categorias.mjs",
    "travel:catalog:tag-categorias:stats": "node scripts/tag-destinos-categorias.mjs --stats",
    "travel:catalog:tag-categorias:db": "node scripts/tag-destinos-categorias.mjs --db",
    "travel:catalog:verify-hotels-geo": "node scripts/verify-wv-hotels-geo.mjs",
    "travel:catalog:verify-hotels-geo:batch": "node scripts/verify-wv-hotels-geo.mjs --batch-size=500",
    "travel:catalog:validate-hotels-coords": "node scripts/validate-hotels-coords.mjs",
    "travel:catalog:validate-hotels-coords-exact": "node scripts/validate-hotels-coords-exact.mjs",

    "travel:catalog:download-ge-hotels": "node scripts/download-geonames-hotels.mjs",
    "travel:catalog:download-ge-hotels:dry": "node scripts/download-geonames-hotels.mjs --dry-run --verbose",
    "travel:catalog:geocode-from-geonames": "node scripts/geocode-from-geonames.mjs",
    "travel:catalog:geocode-from-geonames:dry": "node scripts/geocode-from-geonames.mjs --dry-run --verbose",
    "travel:catalog:geocode-from-geonames:status": "node scripts/geocode-from-geonames.mjs --status",
    "travel:catalog:geocode-dest-geonames": "node scripts/geocode-destinations-geonames.mjs",
    "travel:catalog:geocode-dest-geonames:dry": "node scripts/geocode-destinations-geonames.mjs --dry-run --verbose",
    "travel:catalog:geocode-dest-geonames:status": "node scripts/geocode-destinations-geonames.mjs --status",
    "travel:catalog:geocode-dest-centroid": "node scripts/geocode-destinations-hotel-centroid.mjs",
    "travel:catalog:geocode-dest-centroid:dry": "node scripts/geocode-destinations-hotel-centroid.mjs --dry-run",
    "travel:catalog:geocode-dest-centroid:status": "node scripts/geocode-destinations-hotel-centroid.mjs --status",
    "travel:catalog:validate-ge-distribution": "node scripts/validate-hotels-ge-distribution.mjs",
    "travel:catalog:validate-ge-distribution:full": "node scripts/validate-hotels-ge-distribution.mjs --no-limit",
    "travel:catalog:validate-ge-distribution:top20": "node scripts/validate-hotels-ge-distribution.mjs --limit 20",
    "travel:catalog:classify-hotels": "node scripts/classify-hotel-types.mjs",
    "travel:catalog:classify-hotels:dry-run": "node scripts/classify-hotel-types.mjs --dry-run --limit=100",
    "travel:catalog:import": "node scripts/import-travel-catalog-to-db.mjs",
    "travel:catalog:sync-wiki": "node scripts/sync-destinos-wiki-to-db.mjs",
    "travel:fetch:wikipedia-airports": "node scripts/fetch-wikipedia-airports.mjs",
    "travel:fetch:wikipedia-hotels": "node scripts/fetch-wikipedia-hotels.mjs",
    "travel:fetch:wikipedia-hotel-lists": "node scripts/fetch-wikipedia-hotel-lists.mjs",
    "travel:fetch:wikipedia-hotel-chains": "py -3 -X utf8 scripts/fetch-wikipedia-hotel-chains.py",
    "travel:fetch:wikipedia-hotel-chains:install": "py -3 -m pip install -r scripts/requirements-wikipedia-tables.txt",
    "travel:fetch:wikidata-hotels": "node scripts/fetch-wikidata-hotels.mjs",
    "travel:search:destinos-sem-hotel-wiki": "node scripts/search-destinos-sem-hotel-wiki.mjs",
    "travel:export:destinos-sem-hotel-snapshot": "node scripts/export-destinos-sem-hotel-snapshot.mjs",
    "travel:export:wikivoyage-sleep": "node scripts/export-wikivoyage-sleep-hotels.mjs",
    "travel:wiki:status": "node scripts/travel-wiki-pipeline-status.mjs",
    "travel:wiki:pipeline": "npm run travel:search:destinos-sem-hotel-wiki -- --extracts --limit=50 --delay=400 && npm run travel:demo:apply-wiki-to-bundle && npm run travel:catalog:sync-wiki",
    "travel:pbf:download": "node scripts/download-geofabrik-pbf.mjs",
    "travel:pbf:query": "node scripts/query-pbf-pois.mjs",
    "travel:pbf:query:dry": "node scripts/query-pbf-pois.mjs --dry-run --limit=10",
    "travel:pbf:query:hospitals": "node scripts/query-pbf-pois.mjs --types=hospitals",
    "travel:images:enrich": "node scripts/enrich-bundle-unsplash-images.mjs",
    "travel:images:refresh-duplicates": "cross-env TRAVEL_IMAGES_REFRESH=duplicates node scripts/enrich-bundle-unsplash-images.mjs",
    "travel:images:dedupe": "cross-env TRAVEL_IMAGES_REFRESH=dedupe UNSPLASH_MAX_API_CALLS=400 node scripts/enrich-bundle-unsplash-images.mjs",
    "travel:images:status": "node scripts/travel-images-status.mjs",
    "travel:unsplash:enrich": "node scripts/enrich-bundle-unsplash-images.mjs",
    "travel:ml:export": "node scripts/export-wikivoyage-ml-features.mjs",
    "valhalla:up": "docker compose up valhalla -d",
    "valhalla:logs": "docker compose logs -f valhalla",
    "otp:prepare": "node scripts/otp-prepare.mjs",
    "otp:build": "docker run --rm -e JAVA_TOOL_OPTIONS=-Xmx4g -v ./data/opentripplanner:/var/opentripplanner opentripplanner/opentripplanner:latest --build --save",
    "otp:up": "docker compose up otp -d",
    "otp:logs": "docker compose logs -f otp"
  },
  "dependencies": {
    "@prisma/client": "6.17.1",
    "duckdb": "^1.4.4",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "prisma": "^6.17.1",
    "cross-env": "^7.0.3"
  }
}
